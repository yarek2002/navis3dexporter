<script>
// ===== ПЕРЕКЛЮЧЕНИЕ РЕЖИМОВ ОТОБРАЖЕНИЯ =====
let renderMode = '3d'; // '3d' или 'preview'
let originalLights = []; // Для сохранения оригинальных источников света

function setupPreviewMode() {
    // Сохраняем текущие источники света если еще не сохраняли
    if (originalLights.length === 0) {
        scene.traverse(node => {
            if (node.isLight) {
                originalLights.push({
                    light: node,
                    intensity: node.intensity,
                    visible: node.visible
                });
            }
        });
    }
    
    // Выключаем все существующие источники света
    scene.traverse(node => {
        if (node.isLight) {
            node.visible = false;
        }
    });
    
    // Создаем яркое равномерное освещение
    const ambientLight = new THREE.AmbientLight(0xffffff, 1.5); // Увеличено с 1.0 до 1.5
    ambientLight.name = 'preview_ambient';
    scene.add(ambientLight);
    
    // Добавляем яркие направленные источники со всех сторон
    const light1 = new THREE.DirectionalLight(0xffffff, 1.0); // Увеличено с 0.8 до 1.2
    light1.position.set(1, 1, 1);
    light1.name = 'preview_light1';
    scene.add(light1);
    
    const light2 = new THREE.DirectionalLight(0xffffff, 1.0); // Увеличено с 0.5 до 1.0
    light2.position.set(-1, -0.5, -1);
    light2.name = 'preview_light2';
    scene.add(light2);
    
    const light3 = new THREE.DirectionalLight(0xffffff, 1.0); // Увеличено с 0.3 до 0.8
    light3.position.set(0, 1, 0);
    light3.name = 'preview_light3';
    scene.add(light3);
    
    // Добавляем свет снизу для подсветки теневых областей
    const light4 = new THREE.DirectionalLight(0xffffff, 1.0);
    light4.position.set(0, -1, 0);
    light4.name = 'preview_light4';
    scene.add(light4);
    
    // Добавляем свет сзади
    const light5 = new THREE.DirectionalLight(0xffffff, 1.0);
    light5.position.set(0, 0, 1);
    light5.name = 'preview_light5';
    scene.add(light5);
    
    // Выключаем тени у preview света
    [light1, light2, light3, light4, light5].forEach(light => {
        light.castShadow = false;
    });
    
    // Выключаем тени в рендерере
    renderer.shadowMap.enabled = false;
    
    // Убираем тени у всех объектов
    scene.traverse(node => {
        if (node.isMesh) {
            node.castShadow = false;
            node.receiveShadow = false;
        }
    });
}

function setup3dMode() {
    // Удаляем preview освещение
    const previewLights = [];
    scene.traverse(node => {
        if (node.name && node.name.startsWith('preview_')) {
            previewLights.push(node);
        }
    });
    
    previewLights.forEach(light => {
        scene.remove(light);
    });
    
    // Восстанавливаем оригинальные источники света
    originalLights.forEach(item => {
        if (item.light) {
            item.light.visible = true;
            item.light.intensity = item.intensity;
        }
    });
    
    // Включаем тени
    renderer.shadowMap.enabled = true;
    
    // Восстанавливаем тени у объектов
    scene.traverse(node => {
        if (node.isMesh) {
            node.castShadow = true;
            node.receiveShadow = true;
        }
    });
}

function toggleRenderMode(enable3d) {
    if (enable3d) {
        renderMode = '3d';
        setup3dMode();
    } else {
        renderMode = 'preview';
        setupPreviewMode();
    }
    
    // Обновляем UI
    const toggle = document.getElementById('shadowsEnabledToggle');
    const state = document.getElementById('shadowsEnabledState');
    if (toggle) toggle.checked = enable3d;
    if (state) state.textContent = enable3d ? '3D' : 'Preview';
    
    // Принудительный рендер
    if (renderer) {
        renderer.render(scene, camera);
    }
    
    if (typeof addDebug === 'function') {
        addDebug(`🎨 Режим отображения: ${enable3d ? '3D (с тенями)' : 'Preview (яркое освещение)'}`, 'success');
    }
}

// Инициализация
setTimeout(() => {
    const modeToggle = document.getElementById('shadowsEnabledToggle');
    if (modeToggle) {
        modeToggle.addEventListener('change', function(e) {
            toggleRenderMode(e.target.checked);
        });
    }
    
    // Начальное состояние - 3D режим
    renderMode = '3d';
    
    if (typeof addDebug === 'function') {
        addDebug('🎨 Переключение режимов отображения инициализировано', 'info');
        addDebug('💡 ON = 3D режим (с тенями), OFF = Preview режим (яркое равномерное освещение)', 'info');
    }
}, 2000);
</script>
<script>
// ==================== Режим линейки (вариант 2) ====================
let rulerActive = false;
let rulerPoints = [];
let rulerLine = null;
let rulerStartSphere = null;
let rulerEndSphere = null;
let rulerTextSprite = null;   // для текста в 3D (опционально)

function clearRuler() {
    if (rulerLine)           { scene.remove(rulerLine);           rulerLine = null; }
    if (rulerStartSphere)    { scene.remove(rulerStartSphere);    rulerStartSphere = null; }
    if (rulerEndSphere)      { scene.remove(rulerEndSphere);      rulerEndSphere = null; }
    if (rulerTextSprite)     { scene.remove(rulerTextSprite);     rulerTextSprite = null; }
    rulerPoints = [];
    document.getElementById('ruler-result').innerHTML = '';
}

function createMeasurePoint(pos, isStart = true) {
    const geometry = new THREE.SphereGeometry(0.09, 16, 12);
    const material = new THREE.MeshBasicMaterial({
        color: isStart ? 0x44ff88 : 0xffaa44,
        transparent: true,
        opacity: 0.85
    });
    const sphere = new THREE.Mesh(geometry, material);
    sphere.position.copy(pos);
    scene.add(sphere);
    return sphere;
}
function drawRulerLine() {
    if (rulerPoints.length < 2) return;

    if (rulerLine) {
        scene.remove(rulerLine);
        rulerLine.geometry.dispose();
        rulerLine = null;
    }

    const geometry = new THREE.BufferGeometry().setFromPoints(rulerPoints);

    const material = new THREE.LineBasicMaterial({
        color: 0xffff00,           // жёлтый / любой яркий цвет
        linewidth: 4,              // можно 3–6, в зависимости от вкуса
        transparent: true,         // ← важно!
        opacity: 1.0,              // можно чуть снизить до 0.9–0.95, если хочешь лёгкую полупрозрачность
        depthTest: false,          // ← ключевая строка! отключает проверку глубины
        depthWrite: false          // ← предотвращает запись в буфер глубины (часто нужно вместе с depthTest)
    });

    rulerLine = new THREE.Line(geometry, material);
    rulerLine.renderOrder = 999;   // ← высокий приоритет рендеринга (на всякий случай)

    scene.add(rulerLine);
}

function showDistance() {
    if (rulerPoints.length < 2) return;

    const p1 = rulerPoints[0];
    const p2 = rulerPoints[1];

    const dx = p2.x - p1.x;
    const dy = p2.y - p1.y;
    const dz = p2.z - p1.z;

    const dist = p1.distanceTo(p2);

    const html = `
        <strong style="color:#ffdd66;">Расстояние: ${dist.toFixed(3)} м</strong><br>
        <span style="color:#ff5555;">X:</span> ${dx.toFixed(3)} м<br>
        <span style="color:#55ff55;">Y:</span> ${dy.toFixed(3)} м<br>
        <span style="color:#4488ff;">Z:</span> ${dz.toFixed(3)} м
    `;

    document.getElementById('ruler-result').innerHTML = html;
}

window.toggleRuler = function() {
    rulerActive = !rulerActive;
    
    const btn = document.getElementById('measure-btn');
    if (btn) {
        btn.textContent = `📏 Линейка (${rulerActive ? 'вкл' : 'выкл'})`;
        btn.className = rulerActive ? 'btn success' : 'btn';
    }

    if (!rulerActive) {
        clearRuler();
        addDebug('Линейка выключена', 'info');
    } else {
        clearRuler(); // на всякий случай при включении
        document.getElementById('ruler-result').innerHTML = 'Кликните первую точку...';
        addDebug('Линейка включена — кликните по модели', 'success');
    }
};

// ─── Обработчик клика по canvas ─────────────────────────────────────
renderer.domElement.addEventListener('click', function(event) {
    // Пропускаем если зажат Ctrl (чтобы не мешать существующему выделению)
    if (event.ctrlKey || !rulerActive) return;

    // Предотвращаем конфликт с orbit controls, если нужно
    // event.preventDefault();  // можно включить, если мешает

    const rect = renderer.domElement.getBoundingClientRect();
    const mouse = new THREE.Vector2(
        ((event.clientX - rect.left) / rect.width) * 2 - 1,
        -((event.clientY - rect.top) / rect.height) * 2 + 1
    );

    const raycaster = new THREE.Raycaster();
    raycaster.setFromCamera(mouse, camera);

    // Собираем все меши (можно оптимизировать, если моделей много)
    const meshes = [];
    scene.traverse(node => {
        if (node.isMesh) meshes.push(node);
    });

    const intersects = raycaster.intersectObjects(meshes, false);

    if (intersects.length > 0) {
        const point = intersects[0].point.clone();

        rulerPoints.push(point);

        if (rulerPoints.length === 1) {
            rulerStartSphere = createMeasurePoint(point, true);
            document.getElementById('ruler-result').innerHTML = 'Теперь вторую точку...';
        }
        else if (rulerPoints.length === 2) {
            rulerEndSphere = createMeasurePoint(point, false);
            drawRulerLine();
            showDistance();

            // Можно оставить измерение и ждать выключения режима,
            // либо автоматически очистить после показа:
            // setTimeout(clearRuler, 8000); // авто-очистка через 8 сек
        }
        else {
            // третий и последующие клики → новая линейка
            clearRuler();
            rulerPoints.push(point);
            rulerStartSphere = createMeasurePoint(point, true);
            document.getElementById('ruler-result').innerHTML = 'Теперь вторую точку...';
        }
    }
});

// Очищаем линейку при полной очистке сцены
const originalClearModel = window.clearModel;
window.clearModel = function() {
    clearRuler();
    if (originalClearModel) originalClearModel();
};

const originalV2Clear = window.v2_clearAllModels;
window.v2_clearAllModels = function(...args) {
    clearRuler();
    if (originalV2Clear) originalV2Clear(...args);
};

addDebug('Инструмент линейки (вариант 2) загружен', 'info');
// Показ/скрытие панели информации
document.getElementById('info-toggle-container').addEventListener('click', function() {
  const panel = document.getElementById('info-panel');
  panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
});

// Закрытие по клику вне панели (опционально)
document.addEventListener('click', function(e) {
  const panel = document.getElementById('info-panel');
  const button = document.getElementById('info-toggle-container');
  if (panel.style.display === 'block' && !panel.contains(e.target) && !button.contains(e.target)) {
    panel.style.display = 'none';
