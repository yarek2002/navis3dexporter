    <!-- Тумблер теней в правом верхнем углу -->
	<div id="shadows-toggle-container" style="position: absolute; top: 20px; right: 430px; z-index: 999; background: rgba(30, 30, 40, 0.95); padding: 10px 15px; border-radius: 12px; border: 1px solid #4a6fa5; backdrop-filter: blur(5px); display: flex; align-items: center; gap: 12px;">
	  <span style="color: #ddd; font-size: 14px;">💡 Тени</span>
	  <label class="toggle" style="margin: 0;">
		<input type="checkbox" id="shadowsEnabledToggle" checked>
		<span class="toggle-ui"></span>
		<span class="toggle-state" id="shadowsEnabledState" style="min-width: 42px; text-align: right; color: #aaa;">ON</span>
	  </label>
