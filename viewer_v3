<!DOCTYPE html>
<html>
  <head>
    <base target="_top">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/GLTFLoader.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
    <style>
      body { margin: 0; overflow: hidden; background: #1a1a2e; font-family: 'Segoe UI', Arial; }
      
      #canvas-container {
        width: 100vw;
        height: 100vh;
        position: fixed;
        top: 0;
        left: 0;
      }
      
      #control-panel {
        position: absolute;
        top: 20px;
        left: 20px;
        background: rgba(30, 30, 40, 0.95);
        color: white;
        padding: 20px;
        border-radius: 12px;
        z-index: 100;
        border: 1px solid #4a6fa5;
        box-shadow: 0 4px 20px rgba(0,0,0,0.5);
        width: 380px;
        backdrop-filter: blur(5px);
        max-height: 90vh;
        overflow-y: auto;
        pointer-events: auto;
      }
      
      #debug-window {
        position: absolute;
        top: 20px;
        right: 20px;
        width: 400px;
        max-height: 80vh;
        background: rgba(20, 20, 30, 0.98);
        color: #fff;
        border-radius: 12px;
        z-index: 1000;
        border: 2px solid #ff4444;
        box-shadow: 0 4px 20px rgba(0,0,0,0.7);
        display: flex;
        flex-direction: column;
        font-family: 'Consolas', monospace;
        backdrop-filter: blur(5px);
        resize: both;
        overflow: auto;
        min-width: 300px;
      }
      
      #debug-header {
        padding: 12px 16px;
        background: #2a2a3a;
        border-radius: 10px 10px 0 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 2px solid #ff4444;
        cursor: move;
      }
      
      #debug-header h3 {
        margin: 0;
        color: #ff8888;
        font-size: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      
      #debug-header button {
        background: none;
        border: none;
        color: #aaa;
        cursor: pointer;
        font-size: 20px;
        padding: 0 8px;
      }
      
      #debug-header button:hover {
        color: #ff8888;
      }
      
      #debug-content {
        padding: 16px;
        overflow-y: auto;
        max-height: calc(80vh - 120px);
        font-size: 13px;
        line-height: 1.5;
      }
      
      .debug-entry {
        margin-bottom: 8px;
        padding: 8px;
        border-radius: 6px;
        border-left: 4px solid;
        word-break: break-all;
      }
      
      .debug-info {
        background: #1e3a3a;
        border-left-color: #44aaff;
      }
      
      .debug-success {
        background: #1a3a2a;
        border-left-color: #44ff88;
      }
      
      .debug-warning {
        background: #3a3a1a;
        border-left-color: #ffaa44;
      }
      
      .debug-error {
        background: #3a1a1a;
        border-left-color: #ff4444;
      }
      
      .debug-timestamp {
        color: #888;
        font-size: 11px;
        margin-right: 8px;
      }
      
      #status {
        margin: 10px 0;
        padding: 10px;
        background: #1e1e2e;
        border-radius: 6px;
        font-size: 14px;
      }
      
      .btn {
        background: #4a6fa5;
        color: white;
        border: none;
        padding: 10px 16px;
        border-radius: 6px;
        cursor: pointer;
        margin: 5px 5px 5px 0;
        font-size: 14px;
        transition: all 0.2s;
        border: 1px solid transparent;
      }
      
      .btn:hover {
        background: #5f8bc9;
        transform: translateY(-2px);
      }
      
      .btn.danger {
        background: #a54a4a;
      }
      
      .btn.danger:hover {
        background: #c95f5f;
      }
      
      .btn.success {
        background: #4aa56f;
      }
      
      .btn.success:hover {
        background: #5fc98a;
      }
      
      .btn.warning {
        background: #a58b4a;
      }
      
      .btn.warning:hover {
        background: #c9a85f;
      }
      
      input[type="file"] {
        margin: 10px 0;
        width: 100%;
        padding: 8px;
        background: #1e1e2e;
        color: white;
        border: 1px solid #4a6fa5;
        border-radius: 4px;
        cursor: pointer;
      }
      
      input[type="file"]:hover {
        border-color: #88aaff;
      }
      
      .model-info {
        background: #1e1e2e;
        padding: 10px;
        border-radius: 6px;
        margin-top: 10px;
        font-size: 12px;
        border: 1px solid #3a3a5a;
      }

      /* clipping toggle switch */
      .toggle-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin: 10px 0 6px 0;
      }

      .toggle-label {
        font-size: 13px;
        color: #ddd;
      }

      .toggle {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        user-select: none;
      }

      .toggle input {
        display: none;
      }

      .toggle-ui {
        width: 46px;
        height: 26px;
        border-radius: 999px;
        background: #3a3a5a;
        border: 1px solid #4a6fa5;
        position: relative;
        transition: background 0.2s, border-color 0.2s;
        box-shadow: inset 0 0 0 2px rgba(0,0,0,0.15);
      }

      .toggle-ui::after {
        content: "";
        position: absolute;
        top: 3px;
        left: 3px;
        width: 20px;
        height: 20px;
        border-radius: 999px;
        background: #ddd;
        transition: transform 0.2s, background 0.2s;
      }

      .toggle input:checked + .toggle-ui {
        background: #4aa56f;
        border-color: #5fc98a;
      }

      .toggle input:checked + .toggle-ui::after {
        transform: translateX(20px);
        background: #fff;
      }

      .toggle-state {
        font-size: 12px;
        color: #aaa;
        min-width: 42px;
        text-align: right;
      }

      /* viewer_v2: multi-file GLTF (manifest + .bin) UI */
      .v2-section {
        margin-top: 15px;
        border-top: 1px solid #3a3a5a;
        padding-top: 15px;
      }

      .v2-file-list {
        background: #1e1e2e;
        border: 1px solid #3a3a5a;
        border-radius: 6px;
        padding: 10px;
        margin: 10px 0;
        max-height: 150px;
        overflow-y: auto;
        font-size: 11px;
      }

      .v2-file-group {
        margin-bottom: 10px;
        padding: 8px;
        background: #2a2a3a;
        border-radius: 4px;
      }

      .v2-file-group-title {
        color: #88aaff;
        font-weight: bold;
        margin-bottom: 5px;
      }

      .v2-progress-bar {
        width: 100%;
        height: 8px;
        background: #2a2a3a;
        border-radius: 4px;
        margin: 10px 0;
        overflow: hidden;
      }

      .v2-progress-fill {
        height: 100%;
        background: #4aa56f;
        width: 0%;
        transition: width 0.3s;
      }

      .v2-model-list {
        margin-top: 10px;
        max-height: 200px;
        overflow-y: auto;
      }

      .v2-model-item {
        background: #1e1e2e;
        border: 1px solid #4a6fa5;
        border-radius: 6px;
        padding: 10px;
        margin-bottom: 8px;
        cursor: pointer;
        transition: all 0.2s;
      }

      .v2-model-item:hover {
        background: #2a2a3a;
        border-color: #88aaff;
      }

      .v2-model-item.active {
        background: #2a4a6a;
        border-color: #ffaa44;
      }

      .v2-model-name {
        font-weight: bold;
        color: #88aaff;
      }

      .v2-model-position {
        font-size: 10px;
        color: #aaa;
        margin-top: 4px;
      }
    </style>
  </head>
