          <button class="btn" onclick="window.v2_step1_SelectManifest()">📋 ШАГ 1: Выбрать JSON манифест</button>
          <button class="btn" onclick="window.v2_step2_SelectAllFiles()" id="v2-step2-btn" disabled style="opacity: 0.5;">📁 ШАГ 2: Выбрать ВСЕ файлы (.gltf + .bin)</button>
