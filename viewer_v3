      // Новая функция для принудительного центрирования модели
      function forceCenterModel(model) {
        // Сначала вычисляем bounding box
        const box = new THREE.Box3().setFromObject(model);
        const center = box.getCenter(new THREE.Vector3());
        
        addDebug(`📍 Исходный центр модели: ${center.x.toFixed(2)}, ${center.y.toFixed(2)}, ${center.z.toFixed(2)}`, 'info');
        
        // Создаем временную группу для перемещения всей модели
        const tempGroup = new THREE.Group();
        
        // Сохраняем все дети
        const children = model.children.slice();
        
        // Очищаем модель
        while(model.children.length > 0) {
          model.remove(model.children[0]);
        }
        
        // Добавляем всех детей в группу
        children.forEach(child => {
          tempGroup.add(child);
        });
        
        // Перемещаем группу так, чтобы центр был в 0
        tempGroup.position.copy(center.clone().negate());
        
        // Добавляем группу обратно в модель
        model.add(tempGroup);
        
        addDebug(`✅ Модель принудительно отцентрирована`, 'success');
      }
      
