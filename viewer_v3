      // ===== ФУНКЦИИ CLIPPING =====
      function syncClipToggleUi() {
        const toggle = document.getElementById('clipEnabledToggle');
        const state = document.getElementById('clipEnabledState');
        if (toggle) toggle.checked = clippingEnabled;
        if (state) state.textContent = clippingEnabled ? 'ON' : 'OFF';
      }

      function applyClippingToAllModels() {
    if (!scene || !renderer) return;

    const activePlanes = clippingEnabled ? [
        clipPlanes.X1, clipPlanes.X2,
        clipPlanes.Y1, clipPlanes.Y2,
        clipPlanes.Z1, clipPlanes.Z2
    ] : null;

    let materialsUpdated = 0;

    scene.traverse((node) => {
        if (node.isMesh && node.material) {
            const materials = Array.isArray(node.material) ? node.material : [node.material];
            
            materials.forEach(mat => {
                if (mat) {
                    mat.clippingPlanes = activePlanes;
                    mat.clipIntersection = false;        // важно оставить false
                    mat.clipShadows = true;
                    mat.needsUpdate = true;
                    materialsUpdated++;
                }
            });
        }
    });

    renderer.localClippingEnabled = clippingEnabled;
    renderer.render(scene, camera);
    
    addDebug(`✂ Clipping ${clippingEnabled ? 'включен' : 'выключен'}, обновлено материалов: ${materialsUpdated}`, 'success');
}

      window.toggleClipping = function(forceState) {
        if (typeof forceState === 'boolean') {
          clippingEnabled = forceState;
        } else {
          clippingEnabled = !clippingEnabled;
        }
        
        syncClipToggleUi();
        applyClippingToAllModels();
      };


      // ===== ИНИЦИАЛИЗАЦИЯ THREE.JS =====
