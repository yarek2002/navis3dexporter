      // Анализ модели
      function analyzeModel(model) {
        let meshCount = 0;
        let vertexCount = 0;
        let materialCount = 0;
        const materials = new Set();
        
        model.traverse(function(node) {
          if (node.isMesh) {
            meshCount++;
            if (node.geometry) {
              if (node.geometry.attributes.position) {
                vertexCount += node.geometry.attributes.position.count;
              }
            }
            if (node.material) {
              if (Array.isArray(node.material)) {
                node.material.forEach(m => materials.add(m.type));
              } else {
                materials.add(node.material.type);
              }
            }
          }
        });
        
        materialCount = materials.size;
        
        addDebug(`📊 Анализ модели:`, 'info');
        addDebug(`  - Мешей: ${meshCount}`, 'info');
        addDebug(`  - Вершин: ${vertexCount}`, 'info');
        addDebug(`  - Материалов: ${materialCount}`, 'info');
        
        if (meshCount === 0) {
          addDebug('⚠️ Модель не содержит мешей!', 'warning');
        }
      }

      function ensureMaterials(model) {
        let materialsAdded = 0;
        
        model.traverse(function(node) {
          if (node.isMesh) {
            if (!node.material) {
              node.material = new THREE.MeshStandardMaterial({ 
                color: Math.random() * 0xffffff,
                emissive: 0x222222
              });
              materialsAdded++;
            }
            node.castShadow = true;
            node.receiveShadow = true;
          }
        });
        
        if (materialsAdded > 0) {
          addDebug(`⚠️ Добавлено материалов: ${materialsAdded}`, 'warning');
        }
      }

      function autoFitModel(model) {
        try {
          const box = new THREE.Box3().setFromObject(model);
          const size = box.getSize(new THREE.Vector3());
          const center = box.getCenter(new THREE.Vector3());
          
          addDebug(`📐 Размер модели: ${size.x.toFixed(2)} x ${size.y.toFixed(2)} x ${size.z.toFixed(2)}`, 'info');
          addDebug(`📍 Центр модели: ${center.x.toFixed(2)}, ${center.y.toFixed(2)}, ${center.z.toFixed(2)}`, 'info');
          
          if (size.x === 0 || size.y === 0 || size.z === 0) {
            addDebug('⚠️ Модель имеет нулевой размер!', 'warning');
            return;
          }
          
          const maxDim = Math.max(size.x, size.y, size.z);
          const targetSize = 3;
          const scale = targetSize / maxDim;
          
          model.scale.set(scale, scale, scale);
          addDebug(`📏 Масштаб: ${scale.toFixed(3)}`, 'info');
          
        } catch (e) {
          addDebug(`❌ Ошибка масштабирования: ${e.message}`, 'error');
        }
      }

      function fitCameraToObject(object) {
        try {
          const box = new THREE.Box3().setFromObject(object);
          const size = box.getSize(new THREE.Vector3());
          const center = box.getCenter(new THREE.Vector3());
          
          const maxDim = Math.max(size.x, size.y, size.z);
          const fov = camera.fov * (Math.PI / 180);
          let distance = Math.abs(maxDim / Math.sin(fov / 2));
          
          distance *= 1.5;
          
          if (distance > 10000) distance = 10;
          if (distance < 1) distance = 5;
          if (isNaN(distance)) distance = 5;
          
          camera.position.set(distance, distance * 0.5, distance);
          camera.lookAt(center);
          
          if (controls) {
            controls.target.copy(center);
            controls.update();
          }
          
          addDebug(`📷 Камера настроена: расстояние ${distance.toFixed(2)}`, 'success');
          addDebug(`📷 Цель камеры: (${center.x.toFixed(2)}, ${center.y.toFixed(2)}, ${center.z.toFixed(2)})`, 'info');
          
        } catch (e) {
          addDebug(`❌ Ошибка настройки камеры: ${e.message}`, 'error');
          resetCamera();
        }
      }

      function updateModelInfo(model, name) {
        if (!model) return;
        
        let meshCount = 0;
        let vertexCount = 0;
        
        model.traverse(node => {
          if (node.isMesh) {
            meshCount++;
            if (node.geometry && node.geometry.attributes.position) {
              vertexCount += node.geometry.attributes.position.count;
            }
          }
        });
        
        document.getElementById('model-stats').innerHTML = `
          📛 ${name}<br>
          📦 Мешей: ${meshCount}<br>
          🔷 Вершин: ${vertexCount}<br>
          📏 Масштаб: ${model.scale.x.toFixed(2)}<br>
          📍 Позиция: (${model.position.x.toFixed(2)}, ${model.position.y.toFixed(2)}, ${model.position.z.toFixed(2)})
        `;
      }

      // Анимация
      function animate() {
        requestAnimationFrame(animate);
        
