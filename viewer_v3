            addDebug("❌ Ошибка парсинга GLTF: " + error.message, "error");
          }
        );
      } catch (e) {
        addDebug("❌ Ошибка обработки base64: " + e.message, "error");
      }
    })
    .withFailureHandler(function(error) {
      addDebug("❌ Ошибка сервера: " + (error.message || JSON.stringify(error)), "error");
    })
    .loadModelByNumber(value);  // передаём строку как есть
};
// включение / выключение среза
function syncClipToggleUi() {
  const t = document.getElementById('clipEnabledToggle');
  const s = document.getElementById('clipEnabledState');
  if (t) t.checked = !!clippingEnabled;
  if (s) s.textContent = clippingEnabled ? 'ON' : 'OFF';
}

// Функция применения среза к одной модели
function applyClippingToModel(model) {
  if (!model) return;
  
  model.traverse(function(node) {
    if (!node || !node.isMesh) return;
    
    // Пропускаем, если нет материала
    if (!node.material) return;

    const planes = clippingEnabled ? [
      clipPlanes.X1,
      clipPlanes.X2,
      clipPlanes.Y1,
      clipPlanes.Y2,
      clipPlanes.Z1,
      clipPlanes.Z2
    ] : null;

    // Обрабатываем случай с массивом материалов
    if (Array.isArray(node.material)) {
      node.material.forEach(mat => {
        mat.clippingPlanes = planes;
        mat.needsUpdate = true;
      });
    } else {
      // Один материал
      node.material.clippingPlanes = planes;
      node.material.needsUpdate = true;
    }
  });
}

// Функция применения среза ко всем моделям
function applyClippingToAllModels() {
  if (!scene) return;

  const activePlanes = clippingEnabled ? [
    clipPlanes.X1, clipPlanes.X2,
    clipPlanes.Y1, clipPlanes.Y2,
    clipPlanes.Z1, clipPlanes.Z2
  ] : null;

  let count = 0;

  scene.traverse((node) => {
    if (node.isMesh && node.material) {

      const mats = Array.isArray(node.material) ? node.material : [node.material];

      mats.forEach(mat => {
        if (!mat) return;

        mat.clippingPlanes = activePlanes;
        mat.clipIntersection = true;
        mat.clipShadows = true;
        mat.needsUpdate = true;

        count++;
      });

    }
  });

  renderer.localClippingEnabled = clippingEnabled;

  renderer.render(scene, camera);

  addDebug(`Clipping применён к ${count} материалам`, 'success');
}
// Обновляем функцию toggleClipping
window.toggleClipping = function(forceState) {
  if (typeof forceState === 'boolean') {
    clippingEnabled = forceState;
  } else {
    clippingEnabled = !clippingEnabled;
  }

  syncClipToggleUi();
  applyClippingToAllModels();
  
  updatePlaneHelpers();
  
  addDebug(`✂ Срез ${clippingEnabled ? 'включен + видны плоскости' : 'выключен'}`, 'success');
  
  // Принудительно перерендерим
  if (renderer) {
    renderer.render(scene, camera);
  }
};
// ────────────────────────────────────────────────
// Вспомогательная функция для обновления визуализации при движении ползунков
function updateClipFromSlider() {
  if (clippingEnabled) {
    updatePlaneHelpers();          // перестраиваем плоскости, чтобы они следовали за ползунками
  }
  // можно добавить принудительный рендер, если обновление тормозит
  // renderer.render(scene, camera);
}

// Теперь переопределяем / дополняем существующие обработчики слайдеров

// Находим все слайдеры один раз (чтобы не искать каждый раз)
const clipSliders = {
  clipX:  clipPlanes.X1,
