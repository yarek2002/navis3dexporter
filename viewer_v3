    <script>
      // viewer_v2 logic - ФИЗИЧЕСКОЕ ПЕРЕМЕЩЕНИЕ МОДЕЛЕЙ В ЦЕНТР
      (function() {
        const v2 = {
          modelsMap: new Map(),
          currentManifest: null,
          loadingInProgress: false,
          fileManager: { gltf: new Map(), bin: new Map() },
          globalBoundingBox: new THREE.Box3(),
          hasModels: false,
          sceneCenter: new THREE.Vector3(0, 0, 0),
          sceneSize: new THREE.Vector3(0, 0, 0),
          multiGroup: null,
          scale: 1
        };

        function el(id) { return document.getElementById(id); }

        function safeSetHtml(id, html) {
          const node = el(id);
          if (node) node.innerHTML = html;
        }

        function safeShow(id, show) {
          const node = el(id);
          if (node) node.style.display = show ? 'block' : 'none';
        }

        function resetV2StatsUi() {
          const fill = el('v2-progress-fill');
          if (fill) fill.style.width = '0%';
          safeSetHtml('v2-progress-text', '');
        }

        function setV2Scale(scale) {
          const s = Number(scale);
          if (!isFinite(s) || s <= 0) return;
          
          if (v2.multiGroup) {
            v2.multiGroup.scale.set(s, s, s);
            v2.scale = s;
            
            recalculateGlobalBoundingBox();
            
            const slider = el('v2-scale-slider');
            const label = el('v2-scale-value');
            if (slider) {
              const logv = Math.log10(s);
              if (isFinite(logv)) slider.value = String(logv);
            }
            if (label) label.textContent = `${s.toFixed(2)}×`;
            
            updateModelsList();
            updateV2ModelStats();
            updateCameraToCenter();
          }
        }

        function ensureMultiGroup() {
          if (v2.multiGroup && v2.multiGroup.parent === scene) return;
          v2.multiGroup = new THREE.Group();
          v2.multiGroup.name = 'v2_multi_gltf_group';
          if (scene) scene.add(v2.multiGroup);
          if (typeof currentModel !== 'undefined') {
            currentModel = v2.multiGroup;
          }
        }

        function recalculateGlobalBoundingBox() {
          v2.globalBoundingBox = new THREE.Box3();
          v2.hasModels = false;

          v2.modelsMap.forEach(modelData => {
            if (!modelData || !modelData.visible || !modelData.mesh) return;

            const box = new THREE.Box3().setFromObject(modelData.mesh);
            
            if (!v2.hasModels) {
              v2.globalBoundingBox.copy(box);
              v2.hasModels = true;
            } else {
              v2.globalBoundingBox.union(box);
            }
          });

          if (v2.hasModels) {
            v2.sceneCenter.copy(v2.globalBoundingBox.getCenter(new THREE.Vector3()));
            v2.sceneSize.copy(v2.globalBoundingBox.getSize(new THREE.Vector3()));
          } else {
            v2.sceneCenter.set(0, 0, 0);
            v2.sceneSize.set(0, 0, 0);
          }
        }

        function updateCameraToCenter() {
          if (!v2.hasModels || !camera || !controls) return;
          
          const center = v2.sceneCenter.clone();
          const size = v2.sceneSize.clone();
          const maxDim = Math.max(size.x, size.y, size.z);
          const safeMaxDim = Math.max(maxDim, 0.1);
          
          const fov = camera.fov * (Math.PI / 180);
          let distance = safeMaxDim / Math.sin(fov / 2);
          distance *= 1.5;
          distance = Math.min(Math.max(distance, 1), 100000);
          
          camera.position.set(
            center.x + distance,
            center.y + distance * 0.3,
            center.z + distance
          );
          camera.lookAt(center.x, center.y, center.z);
          
          controls.target.copy(center);
          controls.update();
          
          camera.near = Math.max(0.01, maxDim / 1000);
          camera.far = Math.max(1000, distance * 10, maxDim * 10);
          camera.updateProjectionMatrix();
        }

        function updateFileLists() {
          const gltfList = el('v2-gltf-files-list');
          const binList = el('v2-bin-files-list');
          if (!gltfList || !binList) return;

          gltfList.innerHTML = '';
          v2.fileManager.gltf.forEach((file, name) => {
            gltfList.innerHTML += `<div>📄 ${name}</div>`;
          });

          binList.innerHTML = '';
          v2.fileManager.bin.forEach((file, name) => {
            binList.innerHTML += `<div>💾 ${name}</div>`;
          });
        }

        function updateProgress(loaded, total) {
          const percent = total > 0 ? (loaded / total * 100) : 0;
          const fill = el('v2-progress-fill');
          const text = el('v2-progress-text');
          if (fill) fill.style.width = `${percent.toFixed(0)}%`;
          if (text) text.innerHTML = `${loaded}/${total} (${percent.toFixed(0)}%)`;
        }

        function updateModelsList() {
          const container = el('v2-model-list');
          if (!container) return;

          if (v2.modelsMap.size === 0) {
            container.innerHTML = 'Нет загруженных частей';
            return;
          }

          let html = '';
          v2.modelsMap.forEach((modelData, id) => {
            const visible = !!modelData.visible;
            html += `
              <div class="v2-model-item ${visible ? 'active' : ''}" onclick="window.v2_toggleModelVisibility('${id}')">
                <div class="v2-model-name">${modelData.name}</div>
                <div>${visible ? '👁️ Видима' : '👁️ Скрыта'}</div>
              </div>
            `;
          });

          container.innerHTML = html;
        }

        function updateV2ModelStats() {
          let meshes = 0, vertices = 0;
          let visibleParts = 0;

          v2.modelsMap.forEach(modelData => {
            if (!modelData.mesh) return;
            if (modelData.visible) visibleParts++;
            modelData.mesh.traverse(node => {
              if (node && node.isMesh) {
                meshes++;
                if (node.geometry && node.geometry.attributes && node.geometry.attributes.position) {
                  vertices += node.geometry.attributes.position.count;
                }
              }
            });
          });

          const statsNode = el('v2-model-stats');
          if (statsNode) {
            statsNode.innerHTML = `
              Частей: ${v2.modelsMap.size} (видимых: ${visibleParts})<br>
              Мешей: ${meshes}<br>
              Вершин: ${vertices.toLocaleString()}<br>
              Центр геометрии: X:${v2.sceneCenter.x.toFixed(1)} Y:${v2.sceneCenter.y.toFixed(1)} Z:${v2.sceneCenter.z.toFixed(1)}
            `;
          }
        }

		function loadModelWithDependencies(gltfFile, modelName) {
			return new Promise((resolve, reject) => {
				const reader = new FileReader();

				reader.onload = function(e) {
					const arrayBuffer = e.target.result;
					const loader = new THREE.GLTFLoader();

					const binUrls = new Map();
					v2.fileManager.bin.forEach((file, name) => {
						binUrls.set(name, URL.createObjectURL(file));
					});

					loader.manager.setURLModifier((url) => {
						if (binUrls.has(url)) return binUrls.get(url);
						return url;
					});

					loader.parse(
						arrayBuffer,
						'',
						function(gltf) {
							binUrls.forEach(url => URL.revokeObjectURL(url));

							const model = gltf.scene;
							ensureMultiGroup();
							
							v2.multiGroup.add(model);

							// СОЗДАЕМ modelId ПЕРВЫМ
							const modelId = 'v2_model_' + Date.now() + '_' + Math.random().toString(16).slice(2);
							
							// ТЕПЕРЬ добавляем ссылку на модель в каждый меш (modelId уже существует)
							model.traverse(node => {
								if (node.isMesh) {
									node.userData.parentModelName = modelName;
									node.userData.parentModelId = modelId;
									node.userData.modelName = modelName;
								}
							});

							addDebug(`✅ Часть "${modelName}" добавлена в группу`, 'success');
							
							v2.modelsMap.set(modelId, {
								mesh: model,
								name: modelName,
								visible: true
							});

							resolve({ id: modelId });
						},
						undefined,
						function(error) {
							binUrls.forEach(url => URL.revokeObjectURL(url));
							addDebug(`❌ Ошибка парсинга GLTF: ${error.message || error}`, 'error');
							reject(error);
						}
					);
				};

				reader.onerror = function(error) {
					addDebug(`❌ Ошибка чтения файла GLTF`, 'error');
					reject(error);
				};

				reader.readAsArrayBuffer(gltfFile);
			});
		}
        window.v2_toggleModelVisibility = function(modelId) {
          const modelData = v2.modelsMap.get(modelId);
          if (!modelData || !modelData.mesh) return;

          modelData.visible = !modelData.visible;
          modelData.mesh.visible = modelData.visible;

          recalculateGlobalBoundingBox();
          updateModelsList();
          updateV2ModelStats();
          updateCameraToCenter();
        };

        window.v2_centerScene = function() {
          if (!v2.hasModels || !v2.multiGroup) {
            if (typeof resetCamera === 'function') resetCamera();
            return;
          }

          try {
            addDebug('🎯 Физическое перемещение моделей в центр...', 'info');
            
            v2.multiGroup.position.set(0, 0, 0);
            v2.multiGroup.scale.set(1, 1, 1);
            v2.scale = 1;
            
            const slider = document.getElementById('v2-scale-slider');
            const label = document.getElementById('v2-scale-value');
            if (slider) slider.value = '0';
            if (label) label.textContent = '1.00×';
            
            recalculateGlobalBoundingBox();
            
            if (!v2.hasModels) return;

            const center = v2.sceneCenter.clone();
            const min = v2.globalBoundingBox.min.clone();
            
            addDebug(`📊 Общий центр: (${center.x.toFixed(2)}, ${center.y.toFixed(2)}, ${center.z.toFixed(2)})`, 'info');
            addDebug(`📉 Общий минимум: (${min.x.toFixed(2)}, ${min.y.toFixed(2)}, ${min.z.toFixed(2)})`, 'info');
            
            v2.modelsMap.forEach(modelData => {
              if (!modelData.mesh) return;
              
              const worldPos = modelData.mesh.position.clone();
              
              const offset = new THREE.Vector3(
                -center.x,
                -min.y,
                -center.z
              );
              
              modelData.mesh.position.copy(worldPos.add(offset));
              
              addDebug(`📍 Модель "${modelData.name}" перемещена`, 'info');
            });
            
            recalculateGlobalBoundingBox();
            
            updateCameraToCenter();
            
            updateModelsList();
            updateV2ModelStats();
            
            addDebug('✅ Модели физически перемещены в центр', 'success');
            
          } catch (e) {
            addDebug(`❌ Ошибка центрирования: ${e.message}`, 'error');
            console.error(e);
          }
        };

        window.v2_setScale = function(scale) {
          setV2Scale(scale);
        };

        window.v2_autoScaleToViewport = function() {
          if (!v2.hasModels || !v2.multiGroup) return;
          
          try {
            addDebug('⚖️ Автомасштабирование...', 'info');
            
            const currentPos = v2.multiGroup.position.clone();
            
            v2.multiGroup.scale.set(1, 1, 1);
            
            recalculateGlobalBoundingBox();
            
            const size = v2.sceneSize.clone();
            const maxDim = Math.max(size.x, size.y, size.z);
            
            if (!isFinite(maxDim) || maxDim <= 0) return;
            
            const targetSize = 15;
            let newScale = targetSize / maxDim;
            newScale = Math.min(Math.max(newScale, 0.001), 100);
            
            addDebug(`📏 Размер: ${maxDim.toFixed(2)}, масштаб: ${newScale.toFixed(3)}`, 'info');
            
            v2.multiGroup.scale.set(newScale, newScale, newScale);
            v2.scale = newScale;
            
            v2.multiGroup.position.copy(currentPos);
            
            const slider = el('v2-scale-slider');
            const label = el('v2-scale-value');
            if (slider) {
              const logv = Math.log10(newScale);
              if (isFinite(logv)) slider.value = String(logv);
            }
            if (label) label.textContent = `${newScale.toFixed(2)}×`;
            
            recalculateGlobalBoundingBox();
            updateCameraToCenter();
            
            addDebug(`✅ Масштаб: ${newScale.toFixed(3)}×`, 'success');
            
          } catch (e) {
            addDebug(`❌ Ошибка автомасштаба: ${e.message}`, 'error');
          }
        };

        window.v2_resetView = function() {
          window.v2_centerScene();
        };

        window.v2_clearAllModels = function(options) {
          const opts = options || {};
          try {
            v2.modelsMap.forEach(modelData => {
              if (modelData.mesh && modelData.mesh.parent) {
                modelData.mesh.parent.remove(modelData.mesh);
              }
            });
            v2.modelsMap.clear();
            v2.globalBoundingBox = new THREE.Box3();
            v2.hasModels = false;
            v2.sceneCenter.set(0, 0, 0);
            v2.sceneSize.set(0, 0, 0);

            if (v2.multiGroup && v2.multiGroup.parent) {
              v2.multiGroup.parent.remove(v2.multiGroup);
            }
            v2.multiGroup = null;

            updateModelsList();
            resetV2StatsUi();
            updateV2ModelStats();
            if (!opts.keepUi) {
              safeShow('v2-file-info', false);
              safeShow('v2-manifest-info', false);
            }

            if (!opts.keepManifest) {
              const step2 = el('v2-step2-btn');
              if (step2) { step2.disabled = true; step2.style.opacity = '0.5'; }
              v2.currentManifest = null;
            }
            v2.loadingInProgress = false;

            addDebug('🗑️ Части (манифест) очищены', 'info');

            if (typeof currentModel !== 'undefined' && currentModel && currentModel.name === 'v2_multi_gltf_group') {
              currentModel = null;
            }
          } catch (e) {
            addDebug(`❌ Ошибка очистки частей: ${e.message}`, 'error');
          }
        };

        window.v2_step1_SelectManifest = function() {
          const input = document.createElement('input');
          input.type = 'file';
          input.accept = '.json';

          input.onchange = function(e) {
            const file = e.target.files[0];
            if (!file) return;

            addDebug(`📋 Загрузка манифеста: ${file.name}`, 'info');
            const reader = new FileReader();

            reader.onload = function(e) {
              try {
                v2.currentManifest = JSON.parse(e.target.result);
                const m = v2.currentManifest;

                if (m && m.format === 'navis3dexporter-manifest' && Array.isArray(m.parts)) {
                  addDebug(`✅ Манифест содержит частей: ${m.parts.length}`, 'success');

                  safeShow('v2-manifest-info', true);
                  safeSetHtml('v2-manifest-details', `Файлов GLTF: ${m.parts.length}`);

                  const step2 = el('v2-step2-btn');
                  if (step2) { step2.disabled = false; step2.style.opacity = '1'; }

                  addDebug('👉 Теперь выберите ВСЕ файлы модели (.gltf + .bin)', 'success');
                } else {
                  addDebug('❌ Неверный формат манифеста', 'error');
                }
              } catch (err) {
                addDebug(`❌ Ошибка чтения JSON: ${err.message}`, 'error');
              }
            };

            reader.readAsText(file);
          };

          input.click();
        };

        window.v2_step2_SelectAllFiles = function() {
          if (!v2.currentManifest) {
            addDebug('❌ Сначала загрузите манифест', 'error');
            return;
          }

          if (v2.loadingInProgress) {
            addDebug('⏳ Загрузка уже выполняется, подождите...', 'warning');
            return;
          }

          const input = document.createElement('input');
          input.type = 'file';
          input.multiple = true;
          input.accept = '.gltf,.bin';

          input.onchange = function(e) {
            const files = Array.from(e.target.files || []);
            addDebug(`📁 Выбрано файлов: ${files.length}`, 'info');

            v2.fileManager = { gltf: new Map(), bin: new Map() };

            files.forEach(file => {
              const ext = (file.name.split('.').pop() || '').toLowerCase();
              if (ext === 'gltf') v2.fileManager.gltf.set(file.name, file);
              if (ext === 'bin') v2.fileManager.bin.set(file.name, file);
            });

            window.v2_clearAllModels({ keepManifest: true, keepUi: true });

            updateFileLists();
            safeShow('v2-file-info', true);
            resetV2StatsUi();

            addDebug(`📊 GLTF: ${v2.fileManager.gltf.size}, BIN: ${v2.fileManager.bin.size}`, 'info');

            const parts = v2.currentManifest.parts || [];
            let loaded = 0;
            const total = parts.length;
            v2.loadingInProgress = true;

            function finish() {
              v2.loadingInProgress = false;
              addDebug('✅ Все части обработаны', 'success');
              safeSetHtml('status', '✅ Все части загружены');
              
              setTimeout(() => {
                v2.hasModels = v2.modelsMap.size > 0;
                window.v2_centerScene();
                
                if (clippingEnabled) {
                  setTimeout(applyClippingToAllModels, 100);
                }
              }, 300);
            }

            async function loadSequential() {
              for (let i = 0; i < parts.length; i++) {
                const part = parts[i];
                const fileName = part.file;
                const label = part.label || fileName;
                const gltfFile = v2.fileManager.gltf.get(fileName);

                safeSetHtml('status', `⏳ Загрузка части: ${label}`);
                addDebug(`🔄 Загрузка ${i + 1}/${total}: ${label}`, 'info');

                if (!gltfFile) {
                  addDebug(`⚠️ GLTF не найден: ${fileName}`, 'warning');
                  loaded++;
                  updateProgress(loaded, total);
                  continue;
                }

                try {
                  await loadModelWithDependencies(gltfFile, label);
                } catch (err) {
                  addDebug(`❌ Ошибка загрузки: ${label}`, 'error');
                } finally {
                  loaded++;
                  updateProgress(loaded, total);
                }
              }

              finish();
            }

            loadSequential().catch(e2 => {
              v2.loadingInProgress = false;
              addDebug(`❌ Ошибка: ${e2.message || e2}`, 'error');
            });
          };

          input.click();
        };

        document.addEventListener('DOMContentLoaded', function() {
          const slider = el('v2-scale-slider');
          if (!slider) return;
          slider.addEventListener('input', function(e) {
            const logv = parseFloat(e.target.value);
            const s = Math.pow(10, logv);
            setV2Scale(s);
          });
          setV2Scale(1);
        });
      })();
    </script>
<script>
// ===== ФУНКЦИЯ ДЛЯ ВЫБОРА ОБЪЕКТОВ ПО CTRL+ЛКМ =====
setTimeout(function() {
    if (!renderer || !scene || !camera) {
        console.error('Renderer, scene or camera not found');
        return;
    }

    console.log('Инициализация выбора объектов...');

    let raycaster = new THREE.Raycaster();
    let mouse = new THREE.Vector2();
    let selectedObject = null;
    let isSelecting = false;

    function clearHighlight() {
        if (selectedObject) {
            if (selectedObject.material) {
                if (Array.isArray(selectedObject.material)) {
                    selectedObject.material.forEach(mat => {
                        if (mat.emissive) {
                            mat.emissive.setHex(selectedObject.userData.originalEmissive || 0x000000);
                        }
                    });
                } else if (selectedObject.material.emissive) {
                    selectedObject.material.emissive.setHex(selectedObject.userData.originalEmissive || 0x000000);
                }
            }
            selectedObject = null;
        }
    }

    function highlightObject(object) {
        clearHighlight();
        
        if (object && object.material) {
            if (Array.isArray(object.material)) {
                object.material.forEach(mat => {
                    if (mat.emissive) {
                        object.userData.originalEmissive = mat.emissive.getHex();
                        mat.emissive.setHex(0x444444);
                    }
                });
            } else if (object.material.emissive) {
                object.userData.originalEmissive = object.material.emissive.getHex();
                object.material.emissive.setHex(0x444444);
            }
            selectedObject = object;
        }
    }
	function getObjectInfo(object) {
		let info = {
			name: object.name || 'Без имени',
			type: object.type,
			modelName: 'Неизвестно',
			fullPath: ''
		};
		
		// Собираем путь
		let parent = object;
		let path = [];
		
		while (parent) {
			if (parent.name && parent.name !== '') {
				path.unshift(parent.name);
			}
			parent = parent.parent;
		}
		
		info.fullPath = path.join(' > ');
		
		// ПРОСТОЙ СПОСОБ: берем имя из userData
		if (object.userData && object.userData.parentModelName) {
			info.modelName = object.userData.parentModelName;
			console.log('Найдено в userData:', object.userData.parentModelName);
		}
		
		return info;
	}
	// Обработчик клика на canvas
    renderer.domElement.addEventListener('click', function(event) {
        if (event.ctrlKey) {
            console.log('CTRL+Клик по canvas');
            
            const rect = renderer.domElement.getBoundingClientRect();
            mouse.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
            mouse.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;
            
            raycaster.setFromCamera(mouse, camera);
            
            const meshes = [];
            scene.traverse(node => {
                if (node.isMesh) {
                    meshes.push(node);
                }
            });
            
            const intersects = raycaster.intersectObjects(meshes);
            
            if (intersects.length > 0) {
                const hitObject = intersects[0].object;
                console.log('Попали в объект:', hitObject.name || 'без имени');
                
                if (selectedObject) clearHighlight();
                highlightObject(hitObject);
                
                const info = getObjectInfo(hitObject);
                
                console.log('Найденная модель:', info.modelName);
                console.log('Полный путь:', info.fullPath);
                
                if (typeof addDebug === 'function') {
                    addDebug(`📦 Модель: ${info.modelName}`, 'info');
                }
                
                document.getElementById('status').innerHTML = `Модель: ${info.modelName}`;
                
                // Автоматически вставляем имя модели в поле ввода
                const input = document.getElementById('drive-modelname');
                if (input && info.modelName !== 'Неизвестно') {
                    // Убираем расширение .nwc если оно есть
                    let modelName = info.modelName;
                    if (modelName.endsWith('.nwc')) {
                        modelName = modelName.slice(0, -4);
                    }
                    input.value = modelName;
                }
            } else {
                console.log('Ничего не выбрано');
                clearHighlight();
                document.getElementById('status').innerHTML = '⚪ Готов к загрузке';
            }
        }
    });

    // Снимаем выделение при отпускании Ctrl
    document.addEventListener('keyup', function(event) {
        if (event.key === 'Control') {
            clearHighlight();
            document.getElementById('status').innerHTML = '⚪ Готов к загрузке';
        }
    });

    console.log('Система выбора объектов готова. Используйте CTRL+Клик');
    
}, 2000);
</script>
<script>
// ===== ПЕРЕКЛЮЧЕНИЕ РЕЖИМОВ ОТОБРАЖЕНИЯ =====
let renderMode = '3d'; // '3d' или 'preview'
let originalLights = []; // Для сохранения оригинальных источников света

function setupPreviewMode() {
    // Сохраняем текущие источники света если еще не сохраняли
    if (originalLights.length === 0) {
        scene.traverse(node => {
            if (node.isLight) {
                originalLights.push({
                    light: node,
                    intensity: node.intensity,
                    visible: node.visible
                });
            }
        });
    }
    
    // Выключаем все существующие источники света
    scene.traverse(node => {
        if (node.isLight) {
            node.visible = false;
        }
    });
    
    // Создаем яркое равномерное освещение
    const ambientLight = new THREE.AmbientLight(0xffffff, 1.5); // Увеличено с 1.0 до 1.5
    ambientLight.name = 'preview_ambient';
    scene.add(ambientLight);
    
    // Добавляем яркие направленные источники со всех сторон
    const light1 = new THREE.DirectionalLight(0xffffff, 1.2); // Увеличено с 0.8 до 1.2
    light1.position.set(1, 1, 1);
    light1.name = 'preview_light1';
    scene.add(light1);
    
    const light2 = new THREE.DirectionalLight(0xffffff, 1.0); // Увеличено с 0.5 до 1.0
    light2.position.set(-1, -0.5, -1);
    light2.name = 'preview_light2';
    scene.add(light2);
    
    const light3 = new THREE.DirectionalLight(0xffffff, 0.8); // Увеличено с 0.3 до 0.8
    light3.position.set(0, 1, 0);
    light3.name = 'preview_light3';
    scene.add(light3);
    
    // Добавляем свет снизу для подсветки теневых областей
    const light4 = new THREE.DirectionalLight(0xffffff, 0.6);
    light4.position.set(0, -1, 0);
    light4.name = 'preview_light4';
    scene.add(light4);
    
    // Добавляем свет сзади
    const light5 = new THREE.DirectionalLight(0xffffff, 0.7);
    light5.position.set(0, 0, 1);
    light5.name = 'preview_light5';
    scene.add(light5);
    
    // Выключаем тени у preview света
    [light1, light2, light3, light4, light5].forEach(light => {
        light.castShadow = false;
    });
    
    // Выключаем тени в рендерере
    renderer.shadowMap.enabled = false;
    
    // Убираем тени у всех объектов
    scene.traverse(node => {
        if (node.isMesh) {
            node.castShadow = false;
            node.receiveShadow = false;
        }
    });
}

function setup3dMode() {
    // Удаляем preview освещение
    const previewLights = [];
    scene.traverse(node => {
        if (node.name && node.name.startsWith('preview_')) {
            previewLights.push(node);
        }
    });
    
    previewLights.forEach(light => {
        scene.remove(light);
    });
    
    // Восстанавливаем оригинальные источники света
    originalLights.forEach(item => {
        if (item.light) {
            item.light.visible = true;
            item.light.intensity = item.intensity;
        }
    });
    
    // Включаем тени
    renderer.shadowMap.enabled = true;
    
    // Восстанавливаем тени у объектов
    scene.traverse(node => {
        if (node.isMesh) {
            node.castShadow = true;
            node.receiveShadow = true;
        }
    });
}

function toggleRenderMode(enable3d) {
    if (enable3d) {
        renderMode = '3d';
        setup3dMode();
    } else {
        renderMode = 'preview';
        setupPreviewMode();
    }
    
    // Обновляем UI
    const toggle = document.getElementById('shadowsEnabledToggle');
    const state = document.getElementById('shadowsEnabledState');
    if (toggle) toggle.checked = enable3d;
    if (state) state.textContent = enable3d ? '3D' : 'Preview';
    
    // Принудительный рендер
    if (renderer) {
        renderer.render(scene, camera);
    }
    
    if (typeof addDebug === 'function') {
        addDebug(`🎨 Режим отображения: ${enable3d ? '3D (с тенями)' : 'Preview (яркое освещение)'}`, 'success');
    }
}

// Инициализация
setTimeout(() => {
    const modeToggle = document.getElementById('shadowsEnabledToggle');
    if (modeToggle) {
        modeToggle.addEventListener('change', function(e) {
            toggleRenderMode(e.target.checked);
        });
    }
    
    // Начальное состояние - 3D режим
    renderMode = '3d';
    
    if (typeof addDebug === 'function') {
        addDebug('🎨 Переключение режимов отображения инициализировано', 'info');
        addDebug('💡 ON = 3D режим (с тенями), OFF = Preview режим (яркое равномерное освещение)', 'info');
    }
}, 2000);
</script>
