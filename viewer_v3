			`;
		  });

		  container.innerHTML = html;
		}

// Получаем текущий цвет первой найденной mesh в части
function getModelColor(meshGroup) {
    let color = '#ffffff';
    
    if (!meshGroup) return color;

    meshGroup.traverse(node => {
        if (node.isMesh && node.material) {
            const materials = Array.isArray(node.material) ? node.material : [node.material];
            
            for (let mat of materials) {
                if (mat && mat.color) {
                    // Важно: используем SRGBColorSpace для корректного отображения
                    color = '#' + mat.color.getHexString(THREE.SRGBColorSpace);
                    return false; // выходим после первого найденного
                }
            }
        }
    });
    
    return color;
}

		// Меняем цвет всей части
		window.changePartColor = function(modelId, hexColor) {
		  const modelData = v2.modelsMap.get(modelId);
		  if (!modelData || !modelData.mesh) return;

		  const color = new THREE.Color(hexColor);

		  let changedCount = 0;

		  modelData.mesh.traverse(node => {
			if (node.isMesh && node.material) {
			  // Клонируем материал, если он общий
			  if (node.material === node.material) { // проверка на shared
				node.material = node.material.clone();
			  }
			  
			  if (node.material.color) {
				node.material.color.copy(color);
				node.material.needsUpdate = true;
				changedCount++;
			  }
			}
		  });

		  addDebug(`Цвет части "${modelData.name}" изменён (${changedCount} материалов)`, 'success');

		  // Обновляем UI (маленький и большой список)
		  updateModelsList();
		  syncLargeModalIfOpen(); // если у вас есть эта функция из предыдущего разговора
		};

        function updateV2ModelStats() {
          let meshes = 0, vertices = 0;
          let visibleParts = 0;

          v2.modelsMap.forEach(modelData => {
            if (!modelData.mesh) return;
            if (modelData.visible) visibleParts++;
            modelData.mesh.traverse(node => {
              if (node && node.isMesh) {
                meshes++;
                if (node.geometry && node.geometry.attributes && node.geometry.attributes.position) {
                  vertices += node.geometry.attributes.position.count;
                }
              }
            });
          });

          const statsNode = el('v2-model-stats');
          if (statsNode) {
            statsNode.innerHTML = `
              Частей: ${v2.modelsMap.size} (видимых: ${visibleParts})<br>
              Мешей: ${meshes}<br>
              Вершин: ${vertices.toLocaleString()}<br>
              Центр геометрии: X:${v2.sceneCenter.x.toFixed(1)} Y:${v2.sceneCenter.y.toFixed(1)} Z:${v2.sceneCenter.z.toFixed(1)}
            `;
          }
        }

		function loadModelWithDependencies(gltfFile, modelName) {
			return new Promise((resolve, reject) => {
				const reader = new FileReader();

				reader.onload = function(e) {
					const arrayBuffer = e.target.result;
					const loader = new THREE.GLTFLoader();

					const binUrls = new Map();
					v2.fileManager.bin.forEach((file, name) => {
