		</div>
		<div>
		  <label>Срез Y2 (снизу)</label>
		  <input type="range" id="clipY2" min="-300" max="300" step="0.01" value="0" style="width:100%;">
		</div>
		<div>
		  <label>Срез Z (сзади)</label>
		  <input type="range" id="clipZ" min="-300" max="300" step="0.01" value="0" style="width:100%;">
		</div>
		<div>
		  <label>Срез Z2 (спереди)</label>
