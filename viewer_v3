window.removeModel = function(id) {
    const modelData = v2.modelsMap.get(id);
    if (!modelData) {
        addDebug(`Модель с id ${id} не найдена`, 'warning');
        return;
    }

    const mesh = modelData.mesh;           // ← это корневой Group/Object3D части

    if (mesh) {
        // 1. Удаляем из multiGroup (главное!)
        if (mesh.parent) {
            mesh.parent.remove(mesh);
        } else if (v2.multiGroup) {
            v2.multiGroup.remove(mesh);
        }

        // 2. Полная очистка памяти (очень важно для GLTF)
        disposeObject(mesh);
    }

    // 3. Удаляем из карты
    v2.modelsMap.delete(id);

    // 4. Обновляем всё остальное
    recalculateGlobalBoundingBox();
    updateModelsList();
    updateV2ModelStats();
    updateCameraToCenter();   // если нужно

    if (typeof syncLargeModalIfOpen === 'function') syncLargeModalIfOpen();

    addDebug(`🗑️ Удалена часть: ${modelData.name} (id: ${id})`, 'success');
};

function disposeObject(object) {
    if (!object) return;

    object.traverse((node) => {
        if (node.isMesh) {
            // Геометрия
            if (node.geometry) {
                node.geometry.dispose();
            }

            // Материалы
            const materials = Array.isArray(node.material) ? node.material : [node.material];
            materials.forEach((mat) => {
                if (!mat) return;

                // Текстуры
                if (mat.map) mat.map.dispose();
                if (mat.normalMap) mat.normalMap.dispose();
                if (mat.roughnessMap) mat.roughnessMap.dispose();
                if (mat.metalnessMap) mat.metalnessMap.dispose();
                if (mat.emissiveMap) mat.emissiveMap.dispose();
                // ... добавь другие карты, если используешь

                mat.dispose();
            });
        }
    });

    // Если это анимированная модель — можно очистить анимации
    if (object.animations) {
        object.animations.length = 0;
    }
}

