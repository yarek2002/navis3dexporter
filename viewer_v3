addDebug('Кнопка справки добавлена в правый верхний угол', 'success');

let originalParent = null;

function openLargeModelList() {
  const smallContainer = document.getElementById('v2-model-list');
  if (!smallContainer) return;

  const modal = document.getElementById('large-model-list-modal');
  const largeContent = document.getElementById('large-model-list-content');

  // Сохраняем родителя и перемещаем содержимое
  originalParent = smallContainer.parentNode;
  while (smallContainer.firstChild) {
    largeContent.appendChild(smallContainer.firstChild);
  }

  modal.style.display = 'block';
  setTimeout(() => { modal.style.opacity = '1'; }, 10);
}

function closeLargeModelList() {
  const modal = document.getElementById('large-model-list-modal');
  const largeContent = document.getElementById('large-model-list-content');
  const smallContainer = document.getElementById('v2-model-list');

  if (!smallContainer || !originalParent) return;

  // Возвращаем содержимое обратно
  while (largeContent.firstChild) {
    smallContainer.appendChild(largeContent.firstChild);
  }

  modal.style.opacity = '0';
  setTimeout(() => {
    modal.style.display = 'none';
  }, 300);

  originalParent = null;
}
// Генерирует n контрастных цветов в hex-формате
function generateContrastingColors(count) {
  const colors = [];
  const goldenRatio = 0.618033988749895; // для равномерного распределения по цветовому кругу
  
  for (let i = 0; i < count; i++) {
    // Hue — золотое сечение для максимальной разницы
    const hue = (i * goldenRatio) % 1;
    
    // Насыщенность и яркость — фиксированные, чтобы цвета были яркими и различимыми
    const saturation = 0.85 + Math.random() * 0.15;  // 85–100%
    const value = 0.70 + Math.random() * 0.25;       // 70–95%
    
    // Преобразование HSV → RGB → Hex
    const [r, g, b] = hsvToRgb(hue, saturation, value);
    colors.push(`#${rgbToHex(r, g, b)}`);
  }
  
  return colors;
}

// Вспомогательные функции HSV → RGB → Hex
function hsvToRgb(h, s, v) {
  let r, g, b;
  const i = Math.floor(h * 6);
  const f = h * 6 - i;
  const p = v * (1 - s);
  const q = v * (1 - f * s);
  const t = v * (1 - (1 - f) * s);
  
  switch (i % 6) {
    case 0: r = v; g = t; b = p; break;
    case 1: r = q; g = v; b = p; break;
    case 2: r = p; g = v; b = t; break;
    case 3: r = p; g = q; b = v; break;
    case 4: r = t; g = p; b = v; break;
    case 5: r = v; g = p; b = q; break;
  }
  return [Math.round(r * 255), Math.round(g * 255), Math.round(b * 255)];
}

function rgbToHex(r, g, b) {
  return ((1 << 24) + (r << 16) + (g << 8) + b).toString(16).slice(1).toUpperCase();
}
window.autoAssignContrastingColors = function() {
  if (v2.modelsMap.size === 0) {
    addDebug("Нет загруженных частей для раскрашивания", "warning");
    return;
  }

  const parts = Array.from(v2.modelsMap.values());
  const count = parts.length;
  
  // Генерируем столько контрастных цветов, сколько частей
  const colors = generateContrastingColors(count);
  
  let i = 0;
  v2.modelsMap.forEach((modelData, id) => {
    const colorHex = colors[i % colors.length]; // на случай если цветов меньше
    const color = new THREE.Color(colorHex);
    
    let changed = 0;
    
    modelData.mesh.traverse(node => {
      if (node.isMesh && node.material) {
        // Клонируем материал, если он общий (чтобы не менять другие части)
        if (!node.material.userData?.isCloned) {
          node.material = node.material.clone();
          node.material.userData = node.material.userData || {};
          node.material.userData.isCloned = true;
        }
        
        if (node.material.color) {
          node.material.color.copy(color);
          node.material.needsUpdate = true;
          changed++;
        }
      }
    });
    
    addDebug(`Часть "${modelData.name}" → цвет ${colorHex} (${changed} материалов)`, "success");
    i++;
  });
  
  // Обновляем списки (маленький и большой)
  updateModelsList();
  syncLargeModalIfOpen();   // если у вас есть эта функция
  
  addDebug(`Авто-раскраска завершена: ${count} частей`, "success");
};
// ===== УПРАВЛЕНИЕ ЦВЕТАМИ МОДЕЛЕЙ (JSON) =====
const colorManager = {
    colors: {},
    
    // Загрузить цвета из JSON строки
    loadFromJson: function(jsonData) {
        try {
            this.colors = JSON.parse(jsonData);
            const count = Object.keys(this.colors).length;
            addDebug(`✅ Загружено ${count} цветов из JSON`, 'success');
            return true;
        } catch(e) {
            addDebug(`❌ Ошибка парсинга JSON: ${e.message}`, 'error');
            return false;
        }
    },
    
    // Получить цвет для модели
    getColor: function(modelName) {
        return this.colors[modelName] || null;
    },
    
    // Сохранить цвет (в память)
    setColor: function(modelName, colorHex) {
        this.colors[modelName] = colorHex;
    },
    
    // Экспортировать в JSON строку
    exportToJson: function() {
        return JSON.stringify(this.colors, null, 2);
    },
    
    // Применить цвет к модели
    applyColorToModel: function(model, colorHex) {
        if (!model) return false;
        const color = new THREE.Color(colorHex);
        let changedCount = 0;
        model.traverse(node => {
            if (node.isMesh && node.material) {
                const materials = Array.isArray(node.material) ? node.material : [node.material];
                materials.forEach(mat => {
                    if (mat.color) {
                        mat.color.copy(color);
                        mat.needsUpdate = true;
                        changedCount++;
                    }
                });
            }
        });
        return changedCount > 0;
    },
    
    // Применить цвета ко всем загруженным моделям
    applyToCurrentModels: function() {
        let applied = 0;
        
        if (window.currentModel && window.lastLoadedModelName) {
            const color = this.getColor(window.lastLoadedModelName);
            if (color && this.applyColorToModel(window.currentModel, color)) applied++;
        }
        
        if (window.v2 && window.v2.modelsMap) {
            window.v2.modelsMap.forEach((modelData) => {
                const color = this.getColor(modelData.name);
                if (color && this.applyColorToModel(modelData.mesh, color)) applied++;
            });
        }
        
        // ←←← ДОБАВЛЕНО: сразу обновляем UI список
        if (applied > 0) {
            if (typeof updateModelsList === 'function') updateModelsList();
            if (typeof syncLargeModalIfOpen === 'function') syncLargeModalIfOpen();
        }
        
        if (applied > 0) addDebug(`✅ Применено ${applied} цветов к моделям`, 'success');
        return applied;
    },
    
    // СОБРАТЬ ЦВЕТА С ТЕКУЩИХ МОДЕЛЕЙ (исправлено название)
    collectColorsFromCurrentModels: function() {
        const newColors = {};
        
        // Для одиночной модели
        if (window.currentModel && window.lastLoadedModelName) {
            let colorHex = null;
            window.currentModel.traverse(node => {
                if (!colorHex && node.isMesh && node.material) {
                    const mat = Array.isArray(node.material) ? node.material[0] : node.material;
                    if (mat.color) colorHex = '#' + mat.color.getHexString();
                }
            });
            if (colorHex) newColors[window.lastLoadedModelName] = colorHex;
        }
        
        // Для составных моделей v2
        if (window.v2 && window.v2.modelsMap) {
            window.v2.modelsMap.forEach((modelData) => {
                let colorHex = null;
                modelData.mesh.traverse(node => {
                    if (!colorHex && node.isMesh && node.material) {
                        const mat = Array.isArray(node.material) ? node.material[0] : node.material;
                        if (mat.color) colorHex = '#' + mat.color.getHexString();
                    }
                });
                if (colorHex) newColors[modelData.name] = colorHex;
            });
        }
        
        return newColors;
    }
};

// ===== СОХРАНИТЬ ВСЕ ЦВЕТА В JSON (СОБИРАЕТ АВТОМАТИЧЕСКИ) =====
window.saveColorsToJsonFile = function() {
    // Собираем цвета с текущих моделей (ИСПРАВЛЕНО!)
    const currentColors = colorManager.collectColorsFromCurrentModels();
    const count = Object.keys(currentColors).length;
    
    if (count === 0) {
        addDebug('⚠️ Нет загруженных моделей с цветами для сохранения', 'warning');
        const infoDiv = document.getElementById('json-file-info');
        if (infoDiv) infoDiv.innerHTML = '⚠️ Нет моделей с цветами';
        return;
    }
    
    // Сохраняем в память
    colorManager.colors = currentColors;
    
    // Создаем и скачиваем JSON
    const jsonStr = colorManager.exportToJson();
    const blob = new Blob([jsonStr], {type: 'application/json'});
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'model_colors.json';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
    
    const infoDiv = document.getElementById('json-file-info');
    if (infoDiv) infoDiv.innerHTML = `✅ Сохранено ${count} цветов в model_colors.json`;
    
    addDebug(`💾 Сохранено ${count} цветов (собрано с текущих моделей)`, 'success');
};

// ===== ЗАГРУЗИТЬ ЦВЕТА ИЗ JSON — ИСПРАВЛЕННАЯ ВЕРСИЯ =====
window.loadColorsFromJsonFile = function() {
    const input = document.createElement('input');
    input.type = 'file';
    input.accept = '.json';
    
    input.onchange = function(e) {
        const file = e.target.files[0];
        if (!file) return;
        
        addDebug(`📂 Загрузка цветов: ${file.name}...`, 'info');
        
        const reader = new FileReader();
        reader.onload = function(event) {
            const success = colorManager.loadFromJson(event.target.result);
            
            if (success) {
                colorManager.applyToCurrentModels();

                // Обновляем список и пикеры
                setTimeout(() => {
                    window.updateModelsListGlobal();   // используем глобальную обёртку
                    forceUpdateColorPickers();
                    if (typeof syncLargeModalIfOpen === 'function') syncLargeModalIfOpen();
                    
                    addDebug(`✅ Цвета загружены и список обновлён`, 'success');
                }, 50);
            } else {
                addDebug(`❌ Ошибка парсинга JSON`, 'error');
            }
        };
        
        reader.onerror = function() {
            addDebug(`❌ Ошибка чтения файла`, 'error');
        };
        
        reader.readAsText(file);
    };
    
    input.click();
};

// Принудительно обновляет значение всех color picker в списке
function forceUpdateColorPickers() {
    if (!v2 || !v2.modelsMap) return;

    v2.modelsMap.forEach((modelData, id) => {
        const colorHex = colorManager.getColor(modelData.name) || getModelColor(modelData.mesh) || '#ffffff';
        
        // Обновляем в маленьком списке
        const smallPicker = document.querySelector(`input[onchange="changePartColor('${id}', this.value)"]`);
        if (smallPicker) {
            smallPicker.value = colorHex;
        }

        // Обновляем в большом модальном окне (если открыто)
        const largePicker = document.querySelector(`#large-model-list-content input[onchange="changePartColor('${id}', this.value)"]`);
        if (largePicker) {
            largePicker.value = colorHex;
        }
    });
}
// Глобальная обёртка для updateModelsList
window.updateModelsListGlobal = function() {
    if (typeof updateModelsList === 'function') {
        updateModelsList();
    } else {
        console.warn("updateModelsList is still not accessible");
    }
};
// ===== АВТОМАТИЧЕСКАЯ ЗАГРУЗКА ПРИ СТАРТЕ =====
function autoLoadColorsJson() {
    fetch('model_colors.json')
        .then(response => {
            if (response.ok) return response.text();
            throw new Error('Файл не найден');
        })
        .then(jsonData => {
            colorManager.loadFromJson(jsonData);
            addDebug('✅ Автоматически загружен model_colors.json', 'success');
            
            const infoDiv = document.getElementById('json-file-info');
            if (infoDiv) infoDiv.innerHTML = `✅ Автозагрузка: ${Object.keys(colorManager.colors).length} цветов`;
            
            setTimeout(() => {
                colorManager.applyToCurrentModels();
            }, 500);
        })
        .catch(() => {
            addDebug('ℹ️ Файл model_colors.json не найден', 'info');
        });
}

// ===== ИНИЦИАЛИЗАЦИЯ =====
setTimeout(() => {
    autoLoadColorsJson();
    addDebug('🎨 Система цветов готова. Цвета сохраняются с текущих моделей', 'success');
}, 1000);
</script>
