      <div class="v2-section">
        <h3 style="color:#9b59b6; margin: 0 0 10px 0;">📦 Загрузка GLTF (манифест + BIN)</h3>

        <div style="margin: 10px 0;">
          <button class="btn" onclick="window.v2_step1_SelectManifest()">📋 ШАГ 1: Выбрать JSON манифест</button>
