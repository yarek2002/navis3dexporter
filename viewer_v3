	// Функция конвертации модели из футов в метры
	function convertModelFromFeetToMeters(model) {
		if (!model) return;
		
		// Применяем масштаб для конвертации футов в метры
		model.scale.set(FEET_TO_METERS, FEET_TO_METERS, FEET_TO_METERS);
		
		addDebug(`📏 Конвертация единиц:`, 'success');
		addDebug(`  Модель была в ФУТАХ`, 'info');
		addDebug(`  1 фут = ${FEET_TO_METERS} метра`, 'info');
		addDebug(`  Масштаб: ${FEET_TO_METERS}×`, 'info');
		
		// Вычисляем и показываем реальные размеры в метрах
		const box = new THREE.Box3().setFromObject(model);
		const size = box.getSize(new THREE.Vector3());
		
		addDebug(`📐 Размеры модели в МЕТРАХ:`, 'success');
		addDebug(`  X: ${size.x.toFixed(2)} м (${(size.x / FEET_TO_METERS).toFixed(1)} футов)`, 'info');
		addDebug(`  Y: ${size.y.toFixed(2)} м (${(size.y / FEET_TO_METERS).toFixed(1)} футов)`, 'info');
		addDebug(`  Z: ${size.z.toFixed(2)} м (${(size.z / FEET_TO_METERS).toFixed(1)} футов)`, 'info');
		addDebug(`  `, 'info');
		addDebug(`✅ Теперь 1 клетка сетки = 1 метр`, 'success');
	}


// ===== ИСПРАВЛЕННАЯ СИСТЕМА СРЕЗА =====
let clipPlanes = {
