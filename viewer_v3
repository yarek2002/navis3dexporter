function updateClipPlaneHelpers() {
    const planeSize = 10; // Сделайте чуть больше, чтобы было заметно
    const opacity = 0.35;

    const colors = {
        X1: 0xff4444, X2: 0xff8888,
        Y1: 0x44ff44, Y2: 0x88ff88,
        Z1: 0x4444ff, Z2: 0x88ff88
    };

    Object.keys(clipPlanes).forEach(key => {
        const plane = clipPlanes[key];
        let helper = clipPlaneHelpers[key];

        if (!helper) {
            const geometry = new THREE.PlaneGeometry(planeSize, planeSize);
            const material = new THREE.MeshBasicMaterial({
                color: colors[key],
                side: THREE.DoubleSide,
                transparent: true,
                opacity: opacity,
                depthWrite: false
            });
            helper = new THREE.Mesh(geometry, material);
            scene.add(helper);
            clipPlaneHelpers[key] = helper;
        }

        if (!showClipPlanes) {
            helper.visible = false;
            return;
        }

        helper.visible = true;

        // 1. Позиция: плоскость в Three.js определяется как (Normal * Constant)
        // Для визуализации ставим меш в точку: normal * -constant
        helper.position.set(0, 0, 0); // сброс
        helper.position.addScaledVector(plane.normal, -plane.constant);

        // 2. Поворот: меш должен смотреть вдоль нормали плоскости
        const lookAtPoint = new THREE.Vector3().addVectors(helper.position, plane.normal);
        helper.lookAt(lookAtPoint);
    });
}

