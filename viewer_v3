function updatePlane(value) {

    if (config.side === 'right') {
        clipPlanes.X1.constant = -value;   // ← ВАЖНО
    } 
    else if (config.side === 'left') {
        clipPlanes.X2.constant = value;
    }
    else if (config.side === 'top') {
        clipPlanes.Y1.constant = -value;   // ← ВАЖНО
    }
    else if (config.side === 'bottom') {
        clipPlanes.Y2.constant = value;
    }
    else if (config.side === 'back') {
        clipPlanes.Z1.constant = -value;   // ← ВАЖНО
    }
    else if (config.side === 'front') {
        clipPlanes.Z2.constant = value;
    }
    
    if (clippingEnabled) {
        applyClippingToAllModels();
    }

    if (showClipPlanes) {
        updateClipPlaneHelpers();
    }
}
        
        // Вызываем с текущим значением слайдера
        updatePlane(parseFloat(slider.value));
        
