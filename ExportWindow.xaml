<Window x:Class="Navis3dExporter.ExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Экспорт в GLB"
        Height="210"
        Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Grid.ColumnSpan="3"
                   Margin="0,0,0,8"
                   Text="Папка для сохранения GLB файлов:"
                   VerticalAlignment="Center" />

        <TextBox x:Name="FolderTextBox"
                 Grid.Row="1"
                 Grid.Column="0"
                 Grid.ColumnSpan="2"
                 Margin="0,0,8,0"
                 VerticalAlignment="Center" />

        <Button x:Name="BrowseButton"
                Grid.Row="1"
                Grid.Column="2"
                Content="Обзор..."
                Padding="8,2"
                Click="BrowseButton_OnClick" />

        <StackPanel Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="0,12,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left">
            <TextBlock Text="Режим экспорта:"
                       Margin="0,0,8,0"
                       VerticalAlignment="Center" />
            <RadioButton x:Name="ClashesModeRadio"
                         Content="Коллизии (Clash Detective)"
                         IsChecked="True"
                         Margin="0,0,12,0"
                         VerticalAlignment="Center" />
            <RadioButton x:Name="WholeModelModeRadio"
                         Content="Вся модель"
                         Margin="0,0,12,0"
                         VerticalAlignment="Center" />
            <RadioButton x:Name="SelectionModeRadio"
                         Content="Выделенные объекты"
                         Margin="0,0,12,0"
                         VerticalAlignment="Center" />
            <Button x:Name="SelectClashesButton"
                    Content="Выбрать коллизии для экспорта"
                    Margin="16,0,0,0"
                    Padding="8,2"
                    VerticalAlignment="Center"
                    Click="SelectClashesButton_OnClick" />
        </StackPanel>

        <StackPanel Grid.Row="3"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="RunButton"
                    Content="Запустить"
                    Width="100"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="RunButton_OnClick" />
            <Button x:Name="CancelButton"
                    Content="Отмена"
                    Width="100"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>

