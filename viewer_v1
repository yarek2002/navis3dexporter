window.loadByNumberWithValue = function(value) {
  if (!value) {
    addDebug("❌ Нет значения для загрузки", "error");
    return;
  }

  addDebug(`🔍 Поиск по идентификатору "${value}"`, "info");

  google.script.run
    .withSuccessHandler(function(base64Data) {
      if (!base64Data) {
        addDebug("❌ Пустой base64 от сервера", "error");
        return;
      }
      addDebug("✅ Base64 получен, длина: " + base64Data.length, "success");

      try {
        const binary = atob(base64Data);
        const bytes = new Uint8Array(binary.length);
        for (let i = 0; i < binary.length; i++) {
          bytes[i] = binary.charCodeAt(i);
        }

        const loader = new THREE.GLTFLoader();
        loader.parse(
          bytes.buffer,
          '',
          function (gltf) {
            addDebug("✅ Модель загружена и добавлена", "success");
            if (currentModel) scene.remove(currentModel);
            currentModel = gltf.scene;
            analyzeModel(currentModel);
            ensureMaterials(currentModel);
            forceCenterModel(currentModel);
            autoFitModel(currentModel);
            scene.add(currentModel);
            fitCameraToObject(currentModel);
            controls.autoRotate = true;
            updateModelInfo(currentModel, value);
            document.getElementById('status').innerHTML = `✅ Загружено: ${value}`;
          },
          undefined,
          function (error) {
            addDebug("❌ Ошибка парсинга GLTF: " + error.message, "error");
          }
        );
      } catch (e) {
        addDebug("❌ Ошибка обработки base64: " + e.message, "error");
      }
    })
    .withFailureHandler(function(error) {
      addDebug("❌ Ошибка сервера: " + (error.message || JSON.stringify(error)), "error");
    })
    .loadModelByNumber(value);  // передаём строку как есть
};
// включение / выключение среза
window.toggleClipping = function() {

  clippingEnabled = !clippingEnabled;

  if (!currentModel) return;

  currentModel.traverse(function(node){

    if(node.isMesh){

      if(clippingEnabled){
        node.material.clippingPlanes = [
          clipPlanes.X1,
          clipPlanes.X2,
          clipPlanes.Y1,
          clipPlanes.Y2,
          clipPlanes.Z1,
          clipPlanes.Z2
        ];
      } else {
        node.material.clippingPlanes = null;
      }

      node.material.needsUpdate = true;

    }

  });

};
