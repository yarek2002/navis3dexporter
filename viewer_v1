<!DOCTYPE html>
<html>
  <head>
    <base target="_top">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/GLTFLoader.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
    <style>
      body { margin: 0; overflow: hidden; background: #1a1a2e; font-family: 'Segoe UI', Arial; }
      
      #canvas-container {
        width: 100vw;
        height: 100vh;
        position: fixed;
        top: 0;
        left: 0;
      }
      
      #control-panel {
        position: absolute;
        top: 20px;
        left: 20px;
        background: rgba(30, 30, 40, 0.95);
        color: white;
        padding: 20px;
        border-radius: 12px;
        z-index: 100;
        border: 1px solid #4a6fa5;
        box-shadow: 0 4px 20px rgba(0,0,0,0.5);
        width: 280px;
        backdrop-filter: blur(5px);
        
      }
      
      #debug-window {
        position: absolute;
        top: 20px;
        right: 20px;
        width: 400px;
        max-height: 80vh;
        background: rgba(20, 20, 30, 0.98);
        color: #fff;
        border-radius: 12px;
        z-index: 1000;
        border: 2px solid #ff4444;
        box-shadow: 0 4px 20px rgba(0,0,0,0.7);
        display: flex;
        flex-direction: column;
        font-family: 'Consolas', monospace;
        backdrop-filter: blur(5px);
        resize: both;
        overflow: auto;
        min-width: 300px;
      }
      
      #debug-header {
        padding: 12px 16px;
        background: #2a2a3a;
        border-radius: 10px 10px 0 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 2px solid #ff4444;
        cursor: move;
      }
      
      #debug-header h3 {
        margin: 0;
        color: #ff8888;
        font-size: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      
      #debug-header button {
        background: none;
        border: none;
        color: #aaa;
        cursor: pointer;
        font-size: 20px;
        padding: 0 8px;
      }
      
      #debug-header button:hover {
        color: #ff8888;
      }
      
      #debug-content {
        padding: 16px;
        overflow-y: auto;
        max-height: calc(80vh - 120px);
        font-size: 13px;
        line-height: 1.5;
      }
      
      .debug-entry {
        margin-bottom: 8px;
        padding: 8px;
        border-radius: 6px;
        border-left: 4px solid;
        word-break: break-all;
      }
      
      .debug-info {
        background: #1e3a3a;
        border-left-color: #44aaff;
      }
      
      .debug-success {
        background: #1a3a2a;
        border-left-color: #44ff88;
      }
      
      .debug-warning {
        background: #3a3a1a;
        border-left-color: #ffaa44;
      }
      
      .debug-error {
        background: #3a1a1a;
        border-left-color: #ff4444;
      }
      
      .debug-timestamp {
        color: #888;
        font-size: 11px;
        margin-right: 8px;
      }
      
      #status {
        margin: 10px 0;
        padding: 10px;
        background: #1e1e2e;
        border-radius: 6px;
        font-size: 14px;
      }
      
      .btn {
        background: #4a6fa5;
        color: white;
        border: none;
        padding: 10px 16px;
        border-radius: 6px;
        cursor: pointer;
        margin: 5px 5px 5px 0;
        font-size: 14px;
        transition: all 0.2s;
        border: 1px solid transparent;
      }
      
      .btn:hover {
        background: #5f8bc9;
        transform: translateY(-2px);
      }
      
      .btn.danger {
        background: #a54a4a;
      }
      
      .btn.danger:hover {
        background: #c95f5f;
      }
      
      .btn.success {
        background: #4aa56f;
      }
      
      .btn.success:hover {
        background: #5fc98a;
      }
      
      .btn.warning {
        background: #a58b4a;
      }
      
      .btn.warning:hover {
        background: #c9a85f;
      }
      
      input[type="file"] {
        margin: 10px 0;
        width: 100%;
        padding: 8px;
        background: #1e1e2e;
        color: white;
        border: 1px solid #4a6fa5;
        border-radius: 4px;
        cursor: pointer;
      }
      
      input[type="file"]:hover {
        border-color: #88aaff;
      }
      
      .model-info {
        background: #1e1e2e;
        padding: 10px;
        border-radius: 6px;
        margin-top: 10px;
        font-size: 12px;
        border: 1px solid #3a3a5a;
      }
    </style>
  </head>
  <body>
    <div id="canvas-container"></div>
    
    <div id="control-panel">
      <h3 style="margin-top: 0; color: #4a6fa5;">🎮 Управление 3D</h3>
      
      <div style="margin: 15px 0;">
        <button class="btn success" onclick="window.loadTestModel()">🧪 Тестовая модель</button>
        <button class="btn warning" onclick="window.resetCamera()">📷 Сбросить камеру</button>
        <button class="btn danger" onclick="window.clearModel()">🗑️ Очистить</button>
      </div>
      
      <div>
        <label>📁 Загрузите локальный GLB файл:</label>
        <input type="file" id="file-input" accept=".glb,.gltf">
        <div style="font-size: 12px; color: #aaa; margin-top: 5px;">
          Поддерживаются форматы: .glb, .gltf
        </div>
      </div>

      <div style="margin-top:15px;">
      <label>☁️ Загрузка по номеру из таблицы (Google Drive):</label>
      <input type="text" id="drive-number" placeholder="Номер" style="width:100%;">
      <button class="btn" onclick="window.loadByNumber()">⬇️ Загрузить модель</button>
      <div style="font-size:12px; color:#aaa; margin-top:5px;">
      </div>
      <div style="margin-top:15px;">
      <label>☁️ Загрузка по имени файла (без .glb):</label>
      <input type="text" id="drive-modelname" placeholder="Например: -01_9-13_1 или robot_arm">
      <button class="btn" onclick="window.loadFromDriveByName()">⬇️ Загрузить</button>
      </div>
      <div style="margin-top:15px;border-top:1px solid #3a3a5a;padding-top:10px;">
      <h3 style="color:#ffcc66;">✂️ Срез модели</h3>

      <button class="btn warning" onclick="toggleClipping()">Вкл / Выкл</button>


<div>
<label>Срез X (влево / вправо)</label>
<input type="range" id="clipX" min="-5" max="5" step="0.01" value="0" style="width:100%;">
</div>

<div>
<label>Срез Y (вверх / вниз)</label>
<input type="range" id="clipY" min="-5" max="5" step="0.01" value="0" style="width:100%;">
</div>

<div>
<label>Срез Z (вперёд / назад)</label>
<input type="range" id="clipZ" min="-5" max="5" step="0.01" value="0" style="width:100%;">
</div>
<div>
<label>Срез X2 (справа)</label>
<input type="range" id="clipX2" min="-5" max="5" step="0.01" value="0" style="width:100%;">
</div>

<div>
<label>Срез Y2 (сверху)</label>
<input type="range" id="clipY2" min="-5" max="5" step="0.01" value="0" style="width:100%;">
</div>

<div>
<label>Срез Z2 (спереди)</label>
<input type="range" id="clipZ2" min="-5" max="5" step="0.01" value="0" style="width:100%;">
</div>
</div>

    </div>
          
      <div id="status">
        <span>⚪ Готов к загрузке</span>
      </div>
      
      <div class="model-info" id="model-info">
        <div>📊 Информация о модели:</div>
        <div id="model-stats">Нет загруженной модели</div>
      </div>
    </div>
    
    <div id="debug-window">
      <div id="debug-header">
        <h3>
          <span>🐞 Окно отладки</span>
          <span style="color: #ff4444; font-size: 12px;" id="error-counter">0</span>
        </h3>
        <div>
          <button onclick="window.clearDebug()" title="Очистить">🗑️</button>
          <button onclick="window.toggleDebug()" title="Свернуть">⎯</button>
        </div>
      </div>
      <div id="debug-content">
        <div class="debug-entry debug-info">
          <span class="debug-timestamp">[00:00]</span>
          🔍 Система отладки инициализирована
        </div>
      </div>
    </div>
    
    <script>
      // Глобальные переменные
      const MODEL_FROM_URL = "<?= modelParam ?>";
      let scene, camera, renderer, controls, currentModel;

      // система среза
      let clipPlanes = {
        X1: new THREE.Plane(new THREE.Vector3(1,0,0),100),
        X2: new THREE.Plane(new THREE.Vector3(-1,0,0),100),

        Y1: new THREE.Plane(new THREE.Vector3(0,1,0),100),
        Y2: new THREE.Plane(new THREE.Vector3(0,-1,0),100),

        Z1: new THREE.Plane(new THREE.Vector3(0,0,1),100),
        Z2: new THREE.Plane(new THREE.Vector3(0,0,-1),100)
      };
      let clippingEnabled = false;
      let clipAxis = "Y";
      let debugEntries = [];
      let errorCount = 0;
      let defaultCameraPosition = new THREE.Vector3(4, 3, 5);
      let defaultCameraTarget = new THREE.Vector3(0, 0, 0);
      
      // Делаем функции глобальными
      window.clearDebug = function() {
        debugEntries = [];
        errorCount = 0;
        document.getElementById('error-counter').textContent = '0';
        document.getElementById('debug-content').innerHTML = '';
        addDebug('Окно отладки очищено', 'info');
      };
      
      window.toggleDebug = function() {
        const debugContent = document.getElementById('debug-content');
        debugContent.style.display = debugContent.style.display === 'none' ? 'block' : 'none';
      };
      
      // Функция для добавления сообщений в окно отладки
      function addDebug(message, type = 'info') {
        const date = new Date();
        const timestamp = `[${date.getHours().toString().padStart(2,'0')}:${date.getMinutes().toString().padStart(2,'0')}:${date.getSeconds().toString().padStart(2,'0')}]`;
        
        if (type === 'error') {
          errorCount++;
          document.getElementById('error-counter').textContent = errorCount;
        }
        
        const debugContent = document.getElementById('debug-content');
        const entryDiv = document.createElement('div');
        entryDiv.className = `debug-entry debug-${type}`;
        entryDiv.innerHTML = `<span class="debug-timestamp">${timestamp}</span> ${message}`;
        
        debugContent.appendChild(entryDiv);
        debugContent.scrollTop = debugContent.scrollHeight;
        
        console.log(`[${type}]`, message);
      }
      
      // Функция сброса камеры
      window.resetCamera = function() {
        if (camera && controls) {
          camera.position.copy(defaultCameraPosition);
          controls.target.copy(defaultCameraTarget);
          controls.update();
          addDebug('📷 Камера сброшена в исходное положение', 'success');
        }
      };
      
      // Инициализация Three.js
      addDebug('Инициализация Three.js...', 'info');
      
      try {
        const container = document.getElementById('canvas-container');
        
        // Сцена
        scene = new THREE.Scene();
        scene.background = new THREE.Color(0x1a1a2e);

        
        // Камера
        camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 10000);
        camera.position.copy(defaultCameraPosition);
        camera.lookAt(defaultCameraTarget);
        
        // Рендерер
        renderer = new THREE.WebGLRenderer({ antialias: true, alpha: false });
        renderer.localClippingEnabled = true;
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.shadowMap.enabled = true;
        renderer.shadowMap.type = THREE.PCFSoftShadowMap;
        renderer.setPixelRatio(window.devicePixelRatio);
        container.appendChild(renderer.domElement);
        
        addDebug('✓ Рендерер создан успешно', 'success');
        
        // Освещение
        const ambientLight = new THREE.AmbientLight(0x404060);
        scene.add(ambientLight);
        
        const dirLight = new THREE.DirectionalLight(0xffffff, 1.2);
        dirLight.position.set(2, 5, 3);
        dirLight.castShadow = true;
        dirLight.shadow.mapSize.width = 1024;
        dirLight.shadow.mapSize.height = 1024;
        scene.add(dirLight);
        
        const fillLight = new THREE.PointLight(0x4466ff, 0.5);
        fillLight.position.set(-2, 1, 2);
        scene.add(fillLight);
        
        // Добавляем яркие отладочные источники света
        const frontLight = new THREE.PointLight(0xffffff, 2);
        frontLight.position.set(0, 2, 5);
        scene.add(frontLight);
        
        const topLight = new THREE.PointLight(0xffffff, 1.5);
        topLight.position.set(0, 5, 0);
        scene.add(topLight);
        
        addDebug('💡 Добавлены отладочные источники света', 'info');
        
        // Вспомогательные элементы
        const gridHelper = new THREE.GridHelper(10, 20, 0x88aaff, 0x335588);
        scene.add(gridHelper);
        
        const axesHelper = new THREE.AxesHelper(3);
        scene.add(axesHelper);
        
        addDebug('✓ Сцена настроена, добавлены сетка и оси', 'success');
        
        // Управление
        controls = new THREE.OrbitControls(camera, renderer.domElement);
        controls.enableDamping = true;
        controls.dampingFactor = 0.05;
        controls.autoRotate = false;
        controls.enableZoom = true;
        controls.maxPolarAngle = Math.PI;
        controls.target.copy(defaultCameraTarget);
        
        addDebug('✓ Управление настроено', 'success');
        addDebug('✅ Сцена готова к работе', 'success');
        
      } catch (e) {
        addDebug(`❌ Ошибка инициализации: ${e.message}`, 'error');
      }
      
      // Функция загрузки локального файла
      function loadLocalFile(file) {
        addDebug(`📁 Загрузка файла: ${file.name}`, 'info');
        addDebug(`📊 Размер: ${(file.size / 1024 / 1024).toFixed(2)} MB`, 'info');
        
        const reader = new FileReader();
        
        reader.onload = function(e) {
          addDebug(`✅ Файл прочитан, размер данных: ${(e.target.result.byteLength / 1024 / 1024).toFixed(2)} MB`, 'success');
          
          const arrayBuffer = e.target.result;
          
          // Удаляем предыдущую модель
          if (currentModel) {
            scene.remove(currentModel);
            currentModel = null;
          }
          
          const loader = new THREE.GLTFLoader();
          
          addDebug('🔄 Парсинг GLB файла...', 'info');
          
          loader.parse(
            arrayBuffer,
            '',
            function(gltf) {
              addDebug('✅ Модель успешно загружена!', 'success');
              
              currentModel = gltf.scene;
              
              // Анализируем модель
              analyzeModel(currentModel);
              
              // Проверяем и добавляем материалы если нужно
              ensureMaterials(currentModel);
              
              // ВАЖНО: Принудительно размещаем модель в центре сцены
              forceCenterModel(currentModel);
              
              // Масштабируем под размер сцены
              autoFitModel(currentModel);
              
              // Добавляем модель в сцену
              scene.add(currentModel);
              
              // Принудительно сбрасываем камеру на модель
              fitCameraToObject(currentModel);
              
              // Включаем авто-вращение
              controls.autoRotate = true;
              
              // Обновляем информацию
              updateModelInfo(currentModel, file.name);
              
              document.getElementById('status').innerHTML = `✅ Загружено: ${file.name}`;
            },
            undefined,
            function(error) {
              addDebug(`❌ Ошибка парсинга: ${error.message}`, 'error');
              console.error('Детали ошибки:', error);
              document.getElementById('status').innerHTML = '❌ Ошибка загрузки';
            }
          );
        };
        
        reader.onerror = function(error) {
          addDebug(`❌ Ошибка чтения файла: ${error}`, 'error');
          document.getElementById('status').innerHTML = '❌ Ошибка чтения файла';
        };
        
        reader.readAsArrayBuffer(file);
      }
      window.loadFromDriveByName = function() {
        const modelName = document.getElementById("drive-modelname").value.trim();
        
        if (!modelName) {
          addDebug("❌ Не указано имя модели", "error");
          return;
        }

        addDebug(`☁️ Запрос модели "${modelName}"...`, "info");
        document.getElementById('status').innerHTML = `⏳ Загрузка ${modelName}...`;

        google.script.run
          .withSuccessHandler(function(base64Data) {
            if (!base64Data || base64Data.length < 100) {
              addDebug("❌ Файл не найден или пустой ответ", "error");
              document.getElementById('status').innerHTML = '❌ Модель не найдена';
              return;
            }

            addDebug("✅ Получен файл в base64", "success");

            try {
              const binary = atob(base64Data);
              const bytes = new Uint8Array(binary.length);
              for (let i = 0; i < binary.length; i++) {
                bytes[i] = binary.charCodeAt(i);
              }

              const loader = new THREE.GLTFLoader();
              loader.parse(
                bytes.buffer,
                '',
                function (gltf) {
                  addDebug("✅ Модель успешно загружена!", "success");
                  
                  if (currentModel) scene.remove(currentModel);
                  
                  currentModel = gltf.scene;
                  
                  analyzeModel(currentModel);
                  ensureMaterials(currentModel);
                  forceCenterModel(currentModel);
                  autoFitModel(currentModel);
                  
                  scene.add(currentModel);
                  fitCameraToObject(currentModel);
                  controls.autoRotate = true;
                  
                  updateModelInfo(currentModel, modelName + ".glb");
                  document.getElementById('status').innerHTML = `✅ Загружено: ${modelName}`;
                },
                undefined,
                function (error) {
                  addDebug("❌ Ошибка парсинга: " + error.message, "error");
                  document.getElementById('status').innerHTML = '❌ Ошибка парсинга';
                }
              );

            } catch (e) {
              addDebug("❌ Ошибка декодирования: " + e.message, "error");
              document.getElementById('status').innerHTML = '❌ Ошибка декодирования';
            }
          })
          .withFailureHandler(function(error) {
            addDebug("❌ Ошибка сервера: " + (error.message || JSON.stringify(error)), "error");
            document.getElementById('status').innerHTML = '❌ Ошибка сервера';
          })
          .getDriveGlbBase64ByModelName(modelName);
      };

