};
      // Новая функция для принудительного центрирования модели
      function forceCenterModel(model) {
        // Сначала вычисляем bounding box
        const box = new THREE.Box3().setFromObject(model);
        const center = box.getCenter(new THREE.Vector3());
        
        addDebug(`📍 Исходный центр модели: ${center.x.toFixed(2)}, ${center.y.toFixed(2)}, ${center.z.toFixed(2)}`, 'info');
        
        // Создаем временную группу для перемещения всей модели
        const tempGroup = new THREE.Group();
        
        // Сохраняем все дети
        const children = model.children.slice();
        
        // Очищаем модель
        while(model.children.length > 0) {
          model.remove(model.children[0]);
        }
        
        // Добавляем всех детей в группу
        children.forEach(child => {
          tempGroup.add(child);
        });
        
        // Перемещаем группу так, чтобы центр был в 0
        tempGroup.position.copy(center.clone().negate());
        
        // Добавляем группу обратно в модель
        model.add(tempGroup);
        
        addDebug(`✅ Модель принудительно отцентрирована`, 'success');
      }
      
      // Обработчик выбора файла
      document.getElementById('file-input').addEventListener('change', function(event) {
        const file = event.target.files[0];
        if (file) {
          loadLocalFile(file);
        }
      });
      
      // Тестовая модель
      window.loadTestModel = function() {
        addDebug('🧪 Загрузка тестовой модели...', 'info');
        
        try {
          if (currentModel) {
            scene.remove(currentModel);
          }
          
          const group = new THREE.Group();
          
          // Красный куб
          const cubeGeo = new THREE.BoxGeometry(1, 1, 1);
          const cubeMat = new THREE.MeshStandardMaterial({ color: 0xff4444, emissive: 0x331111 });
          const cube = new THREE.Mesh(cubeGeo, cubeMat);
          cube.position.set(0, 0.5, 0);
          group.add(cube);
          
          // Синяя сфера
          const sphereGeo = new THREE.SphereGeometry(0.5, 32, 32);
          const sphereMat = new THREE.MeshStandardMaterial({ color: 0x44aaff, emissive: 0x112233 });
          const sphere = new THREE.Mesh(sphereGeo, sphereMat);
          sphere.position.set(1.5, 0.5, 0);
          group.add(sphere);
          
          // Зеленый тор
          const torusGeo = new THREE.TorusGeometry(0.8, 0.2, 16, 100);
          const torusMat = new THREE.MeshStandardMaterial({ color: 0x88ff88, emissive: 0x113311 });
          const torus = new THREE.Mesh(torusGeo, torusMat);
          torus.position.set(-1.5, 0.5, 0);
          torus.rotation.x = Math.PI / 2;
          group.add(torus);
          
          currentModel = group;
          scene.add(currentModel);
          
          // Сбрасываем камеру на тестовую модель
          fitCameraToObject(currentModel);
          
          addDebug('✅ Тестовая модель загружена', 'success');
          document.getElementById('status').innerHTML = '✅ Тестовая модель';
          
          updateModelInfo(currentModel, 'Тестовая модель');
          controls.autoRotate = true;
          
        } catch (e) {
          addDebug(`❌ Ошибка: ${e.message}`, 'error');
        }
      };
      
      // Очистка сцены
      window.clearModel = function() {
        if (currentModel) {
          scene.remove(currentModel);
          currentModel = null;
          addDebug('🗑️ Модель удалена', 'info');
          document.getElementById('status').innerHTML = '⚪ Сцена очищена';
          document.getElementById('model-stats').innerHTML = 'Нет загруженной модели';
          controls.autoRotate = false;
          
          // Сбрасываем камеру
          resetCamera();
        }
      };
      
      // Анализ модели
      function analyzeModel(model) {
        let meshCount = 0;
        let vertexCount = 0;
        let materialCount = 0;
        const materials = new Set();
        
        model.traverse(function(node) {
          if (node.isMesh) {
            meshCount++;
            if (node.geometry) {
              if (node.geometry.attributes.position) {
                vertexCount += node.geometry.attributes.position.count;
              }
            }
            if (node.material) {
              if (Array.isArray(node.material)) {
                node.material.forEach(m => materials.add(m.type));
              } else {
                materials.add(node.material.type);
              }
            }
          }
        });
        
        materialCount = materials.size;
        
        addDebug(`📊 Анализ модели:`, 'info');
        addDebug(`  - Мешей: ${meshCount}`, 'info');
        addDebug(`  - Вершин: ${vertexCount}`, 'info');
        addDebug(`  - Материалов: ${materialCount}`, 'info');
        
        if (meshCount === 0) {
          addDebug('⚠️ Модель не содержит мешей!', 'warning');
        }
      }
      
      // Проверка видимости модели
      function debugModelVisibility(model) {
        if (!model) {
          addDebug('❌ Модель не существует', 'error');
          return;
        }
        
        addDebug('🔍 Проверка видимости модели:', 'info');
        
        // Проверяем позицию
        addDebug(`  Позиция: (${model.position.x.toFixed(2)}, ${model.position.y.toFixed(2)}, ${model.position.z.toFixed(2)})`, 'info');
        
        // Проверяем масштаб
        addDebug(`  Масштаб: (${model.scale.x.toFixed(2)}, ${model.scale.y.toFixed(2)}, ${model.scale.z.toFixed(2)})`, 'info');
        
        // Проверяем видимость
        addDebug(`  Видимость: ${model.visible ? '✅' : '❌'}`, model.visible ? 'success' : 'error');
        
        // Проверяем bounding box
        const box = new THREE.Box3().setFromObject(model);
        const size = box.getSize(new THREE.Vector3());
        addDebug(`  Bounding box размер: (${size.x.toFixed(2)}, ${size.y.toFixed(2)}, ${size.z.toFixed(2)})`, 'info');
        
        // Проверяем материалы
        let hasVisibleMaterial = false;
        model.traverse(node => {
          if (node.isMesh && node.material) {
            if (Array.isArray(node.material)) {
              node.material.forEach(mat => {
                if (mat.visible) hasVisibleMaterial = true;
              });
            } else {
              if (node.material.visible) hasVisibleMaterial = true;
            }
          }
        });
        
        addDebug(`  Видимые материалы: ${hasVisibleMaterial ? '✅' : '❌'}`, hasVisibleMaterial ? 'success' : 'error');
        
        // Проверяем наличие геометрии
        let hasGeometry = false;
        model.traverse(node => {
          if (node.isMesh && node.geometry) {
            hasGeometry = true;
          }
        });
        
        addDebug(`  Наличие геометрии: ${hasGeometry ? '✅' : '❌'}`, hasGeometry ? 'success' : 'error');
      }
      
      // Проверка и добавление материалов
      function ensureMaterials(model) {
        let materialsAdded = 0;
        
        model.traverse(function(node) {
          if (node.isMesh) {
            if (!node.material) {
              node.material = new THREE.MeshStandardMaterial({ 
                color: Math.random() * 0xffffff,
                emissive: 0x222222
              });
              materialsAdded++;
            }
            node.castShadow = true;
            node.receiveShadow = true;
          }
        });
        
        if (materialsAdded > 0) {
          addDebug(`⚠️ Добавлено материалов: ${materialsAdded}`, 'warning');
        }
      }
      
      // Улучшенная функция автоматического масштабирования
      function autoFitModel(model) {
        try {
          // Вычисляем bounding box модели
          const box = new THREE.Box3().setFromObject(model);
          const size = box.getSize(new THREE.Vector3());
          const center = box.getCenter(new THREE.Vector3());
          
          addDebug(`📐 Размер модели: ${size.x.toFixed(2)} x ${size.y.toFixed(2)} x ${size.z.toFixed(2)}`, 'info');
          addDebug(`📍 Центр модели: ${center.x.toFixed(2)}, ${center.y.toFixed(2)}, ${center.z.toFixed(2)}`, 'info');
          
          if (size.x === 0 || size.y === 0 || size.z === 0) {
            addDebug('⚠️ Модель имеет нулевой размер!', 'warning');
            return;
          }
          
          // Масштабируем модель
          const maxDim = Math.max(size.x, size.y, size.z);
          const targetSize = 3;
          const scale = targetSize / maxDim;
          
          model.scale.set(scale, scale, scale);
          addDebug(`📏 Масштаб: ${scale.toFixed(3)}`, 'info');
          
        } catch (e) {
          addDebug(`❌ Ошибка масштабирования: ${e.message}`, 'error');
        }
      }
      
      // Функция для настройки камеры на объект
      function fitCameraToObject(object) {
        try {
          const box = new THREE.Box3().setFromObject(object);
          const size = box.getSize(new THREE.Vector3());
          const center = box.getCenter(new THREE.Vector3());
          
          // Вычисляем расстояние до камеры
          const maxDim = Math.max(size.x, size.y, size.z);
          const fov = camera.fov * (Math.PI / 180);
          let distance = Math.abs(maxDim / Math.sin(fov / 2));
          
          // Добавляем запас
          distance *= 1.5;
          
          // Проверяем на экстремальные значения
          if (distance > 10000) distance = 10;
          if (distance < 1) distance = 5;
          if (isNaN(distance)) distance = 5;
          
          // Позиционируем камеру
          camera.position.set(distance, distance * 0.5, distance);
          camera.lookAt(center);
          
          // Настраиваем controls
          if (controls) {
            controls.target.copy(center);
            controls.update();
          }
          
          addDebug(`📷 Камера настроена: расстояние ${distance.toFixed(2)}`, 'success');
          addDebug(`📷 Цель камеры: (${center.x.toFixed(2)}, ${center.y.toFixed(2)}, ${center.z.toFixed(2)})`, 'info');
          
        } catch (e) {
          addDebug(`❌ Ошибка настройки камеры: ${e.message}`, 'error');
          // В случае ошибки сбрасываем камеру
          resetCamera();
        }
      }
      
      // Обновление информации о модели
      function updateModelInfo(model, name) {
        if (!model) return;
        
        let meshCount = 0;
        let vertexCount = 0;
        
        model.traverse(node => {
          if (node.isMesh) {
            meshCount++;
            if (node.geometry && node.geometry.attributes.position) {
              vertexCount += node.geometry.attributes.position.count;
            }
          }
        });
        
        document.getElementById('model-stats').innerHTML = `
          📛 ${name}<br>
          📦 Мешей: ${meshCount}<br>
          🔷 Вершин: ${vertexCount}<br>
          📏 Масштаб: ${model.scale.x.toFixed(2)}<br>
          📍 Позиция: (${model.position.x.toFixed(2)}, ${model.position.y.toFixed(2)}, ${model.position.z.toFixed(2)})
        `;
      }
            // автозагрузка модели из URL
      window.addEventListener("load", function () {

        if (MODEL_FROM_URL) {

          addDebug("📦 Модель из URL: " + MODEL_FROM_URL, "info");

          document.getElementById("drive-modelname").value = MODEL_FROM_URL;

          window.loadFromDriveByName();

        }

      });
      // Анимация
      function animate() {
        requestAnimationFrame(animate);
        
        if (controls) {
          controls.update();
        }
        
        if (renderer && scene && camera) {
          renderer.render(scene, camera);
        }
      }
      animate();
      
      // Обработка изменения размера окна
      window.addEventListener('resize', function() {
        if (camera) {
          camera.aspect = window.innerWidth / window.innerHeight;
          camera.updateProjectionMatrix();
        }
        if (renderer) {
          renderer.setSize(window.innerWidth, window.innerHeight);
        }
      });
      
      // Перетаскивание окна отладки
      let isDragging = false;
      let dragOffsetX, dragOffsetY;
      
      document.getElementById('debug-header').addEventListener('mousedown', function(e) {
        isDragging = true;
        const debugWindow = document.getElementById('debug-window');
        dragOffsetX = e.clientX - debugWindow.offsetLeft;
        dragOffsetY = e.clientY - debugWindow.offsetTop;
      });
      
      document.addEventListener('mousemove', function(e) {
        if (isDragging) {
          const debugWindow = document.getElementById('debug-window');
          debugWindow.style.left = (e.clientX - dragOffsetX) + 'px';
          debugWindow.style.top = (e.clientY - dragOffsetY) + 'px';
          debugWindow.style.right = 'auto';
        }
      });
      
      document.addEventListener('mouseup', function() {
        isDragging = false;
      });
      
      addDebug('✅ Система готова. Выберите GLB файл для загрузки', 'success');
      // управление срезами по осям

