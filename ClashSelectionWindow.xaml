<Window x:Class="Navis3dExporter.ClashSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор коллизий для экспорта"
        Height="400"
        Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DataGrid x:Name="ClashesGrid"
                  Grid.Row="0"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserSortColumns="True"
                  IsReadOnly="False"
                  SelectionMode="Extended"
                  HeadersVisibility="Column"
                  PreviewMouseLeftButtonDown="ClashesGrid_PreviewMouseLeftButtonDown">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header=""
                                       Width="40"
                                       Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <DataGridTextColumn Header="Имя коллизии"
                                    Binding="{Binding Name}"
                                    Width="*" />
                <DataGridTextColumn Header="Статус"
                                    Binding="{Binding Status}"
                                    Width="200" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button Content="Закрыть"
                    Width="100"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>

