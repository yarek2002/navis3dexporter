<!DOCTYPE html>
<html>
  <head>
    <base target="_top">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/GLTFLoader.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
    <style>
      body { margin: 0; overflow: hidden; background: #1a1a2e; font-family: 'Segoe UI', Arial; }
      
      #canvas-container {
        width: 100vw;
        height: 100vh;
        position: fixed;
        top: 0;
        left: 0;
        z-index: 1;
      }
      
      #control-panel {
        position: absolute;
        top: 20px;
        left: 20px;
        background: rgba(30, 30, 40, 0.95);
        color: white;
        padding: 20px;
        border-radius: 12px;
        z-index: 100;
        border: 1px solid #4a6fa5;
        box-shadow: 0 4px 20px rgba(0,0,0,0.5);
        width: 380px;
        backdrop-filter: blur(5px);
        max-height: 90vh;
        overflow-y: auto;
        pointer-events: auto;
      }
      
      #debug-window {
        position: absolute;
        top: 20px;
        right: 20px;
        width: 450px;
        max-height: 80vh;
        background: rgba(20, 20, 30, 0.98);
        color: #fff;
        border-radius: 12px;
        z-index: 1000;
        border: 2px solid #ff4444;
        box-shadow: 0 4px 20px rgba(0,0,0,0.7);
        display: flex;
        flex-direction: column;
        font-family: 'Consolas', monospace;
        backdrop-filter: blur(5px);
        resize: both;
        overflow: auto;
        min-width: 350px;
        pointer-events: auto;
      }
      
      #debug-header {
        padding: 12px 16px;
        background: #2a2a3a;
        border-radius: 10px 10px 0 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 2px solid #ff4444;
        cursor: move;
      }
      
      #debug-header h3 {
        margin: 0;
        color: #ff8888;
        font-size: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      
      #debug-header button {
        background: none;
        border: none;
        color: #aaa;
        cursor: pointer;
        font-size: 20px;
        padding: 0 8px;
      }
      
      #debug-header button:hover {
        color: #ff8888;
      }
      
      #debug-content {
        padding: 16px;
        overflow-y: auto;
        max-height: calc(80vh - 120px);
        font-size: 12px;
        line-height: 1.5;
      }
      
      .debug-entry {
        margin-bottom: 8px;
        padding: 8px;
        border-radius: 6px;
        border-left: 4px solid;
        word-break: break-all;
      }
      
      .debug-info {
        background: #1e3a3a;
        border-left-color: #44aaff;
      }
      
      .debug-success {
        background: #1a3a2a;
        border-left-color: #44ff88;
      }
      
      .debug-warning {
        background: #3a3a1a;
        border-left-color: #ffaa44;
      }
      
      .debug-error {
        background: #3a1a1a;
        border-left-color: #ff4444;
      }
      
      .debug-timestamp {
        color: #888;
        font-size: 10px;
        margin-right: 8px;
      }
      
      #status {
        margin: 10px 0;
        padding: 12px;
        background: #1e1e2e;
        border-radius: 6px;
        font-size: 14px;
        border-left: 4px solid #4a6fa5;
      }
      
      .btn {
        background: #4a6fa5;
        color: white;
        border: none;
        padding: 12px 16px;
        border-radius: 6px;
        cursor: pointer;
        margin: 5px 0;
        font-size: 14px;
        transition: all 0.2s;
        border: 1px solid transparent;
        width: 100%;
        text-align: left;
      }
      
      .btn:hover {
        background: #5f8bc9;
        transform: translateY(-2px);
      }
      
      .btn.danger {
        background: #a54a4a;
      }
      
      .btn.danger:hover {
        background: #c95f5f;
      }
      
      .btn.success {
        background: #4aa56f;
      }
      
      .btn.success:hover {
        background: #5fc98a;
      }
      
      .btn.purple {
        background: #9b59b6;
      }
      
      .btn.purple:hover {
        background: #af7ac5;
      }
      
      .file-list {
        background: #1e1e2e;
        border: 1px solid #3a3a5a;
        border-radius: 6px;
        padding: 10px;
        margin: 10px 0;
        max-height: 150px;
        overflow-y: auto;
        font-size: 11px;
      }
      
      .file-group {
        margin-bottom: 10px;
        padding: 8px;
        background: #2a2a3a;
        border-radius: 4px;
      }
      
      .file-group-title {
        color: #88aaff;
        font-weight: bold;
        margin-bottom: 5px;
      }
      
      .progress-bar {
        width: 100%;
        height: 8px;
        background: #2a2a3a;
        border-radius: 4px;
        margin: 10px 0;
        overflow: hidden;
      }
      
      .progress-fill {
        height: 100%;
        background: #4aa56f;
        width: 0%;
        transition: width 0.3s;
      }
      
      .model-list {
        margin-top: 15px;
        border-top: 1px solid #3a3a5a;
        padding-top: 15px;
        max-height: 200px;
        overflow-y: auto;
      }
      
      .model-item {
        background: #1e1e2e;
        border: 1px solid #4a6fa5;
        border-radius: 6px;
        padding: 10px;
        margin-bottom: 8px;
        cursor: pointer;
        transition: all 0.2s;
      }
      
      .model-item:hover {
        background: #2a2a3a;
        border-color: #88aaff;
      }
      
      .model-item.active {
        background: #2a4a6a;
        border-color: #ffaa44;
      }
      
      .model-name {
        font-weight: bold;
        color: #88aaff;
      }
      
      .model-position {
        font-size: 10px;
        color: #aaa;
        margin-top: 4px;
      }
    </style>
  </head>
  <body>
    <div id="canvas-container"></div>
    
    <div id="control-panel">
      <h3 style="margin-top: 0; color: #4a6fa5;">🎮 Navis3D Viewer</h3>
      
      <div style="margin: 15px 0;">
        <button class="btn success" onclick="window.loadTestModel()">🧪 Тестовая сцена</button>
        <button class="btn warning" onclick="window.resetCamera()">📷 Сбросить камеру</button>
        <button class="btn danger" onclick="window.clearAllModels()">🗑️ Очистить всё</button>
        <button class="btn" onclick="window.centerScene()">🎯 Центрировать сцену</button>
      </div>
      
      <button class="btn purple" onclick="window.step1_SelectManifest()">
        📋 ШАГ 1: Выбрать JSON манифест
      </button>
      <button class="btn purple" onclick="window.step2_SelectAllFiles()" id="step2-btn" disabled style="opacity: 0.5;">
        📁 ШАГ 2: Выбрать ВСЕ файлы
      </button>
      
      <div id="manifest-info" style="display: none; margin: 10px 0; padding: 10px; background: #1a3a2a; border-radius: 6px;">
        <div style="font-size: 12px;">✅ Манифест загружен</div>
        <div id="manifest-details" style="font-size: 11px; color: #aaa;"></div>
      </div>

      <div id="file-info" style="display: none;">
        <div class="file-group">
          <div class="file-group-title">📋 GLTF файлы:</div>
          <div class="file-list" id="gltf-files-list"></div>
        </div>
        <div class="file-group">
          <div class="file-group-title">💾 BIN файлы:</div>
          <div class="file-list" id="bin-files-list"></div>
        </div>
        <div class="progress-bar">
          <div class="progress-fill" id="progress-fill"></div>
        </div>
        <div id="progress-text" style="font-size: 11px; text-align: right;"></div>
      </div>

      <div class="model-list">
        <h4 style="margin: 0 0 10px 0; color: #4a6fa5;">📋 Загруженные модели</h4>
        <div id="model-list">Нет загруженных моделей</div>
      </div>
          
      <div id="status">⚪ Готов к загрузке</div>
      
      <div class="model-info">
        <div>📊 Статистика:</div>
        <div id="model-stats">Нет данных</div>
      </div>
    </div>
    
    <div id="debug-window">
      <div id="debug-header">
        <h3>
          <span>🐞 Отладка</span>
          <span style="color: #ff4444;" id="error-counter">0</span>
        </h3>
        <div>
          <button onclick="window.clearDebug()">🗑️</button>
          <button onclick="window.toggleDebug()">⎯</button>
        </div>
      </div>
      <div id="debug-content"></div>
    </div>
    
    <script>
      // Глобальные переменные
      let scene, camera, renderer, controls;
      let modelsMap = new Map();
      let defaultCameraPosition = new THREE.Vector3(0, 10, 30);
      let defaultCameraTarget = new THREE.Vector3(0, 0, 0);
      let errorCount = 0;
      let currentManifest = null;
      let loadingInProgress = false;
      let animationId = null;
      let fileManager = {
        gltf: new Map(),
        bin: new Map()
      };
      
      // Для отслеживания общего bounding box
      let globalBoundingBox = new THREE.Box3();
      let hasModels = false;
      let sceneCenter = new THREE.Vector3(0, 0, 0);
      let sceneSize = new THREE.Vector3(0, 0, 0);
      
      // Отладка
      window.clearDebug = function() {
        document.getElementById('debug-content').innerHTML = '';
        errorCount = 0;
        document.getElementById('error-counter').textContent = '0';
      };
      
      window.toggleDebug = function() {
        const debugContent = document.getElementById('debug-content');
        debugContent.style.display = debugContent.style.display === 'none' ? 'block' : 'none';
      };
      
      function addDebug(message, type = 'info') {
        const date = new Date();
        const timestamp = `[${date.getHours().toString().padStart(2,'0')}:${date.getMinutes().toString().padStart(2,'0')}:${date.getSeconds().toString().padStart(2,'0')}]`;
        
        if (type === 'error') errorCount++;
        document.getElementById('error-counter').textContent = errorCount;
        
        const debugContent = document.getElementById('debug-content');
        const entryDiv = document.createElement('div');
        entryDiv.className = `debug-entry debug-${type}`;
        entryDiv.innerHTML = `<span class="debug-timestamp">${timestamp}</span> ${message}`;
        
        debugContent.appendChild(entryDiv);
        debugContent.scrollTop = debugContent.scrollHeight;
        console.log(`[${type}]`, message);
      }
      
      // Сброс камеры
      window.resetCamera = function() {
        if (camera && controls) {
          camera.position.copy(defaultCameraPosition);
          controls.target.copy(defaultCameraTarget);
          controls.update();
          addDebug('📷 Камера сброшена', 'success');
        }
      };

      // Центрирование сцены
      window.centerScene = function() {
        if (!hasModels) {
          resetCamera();
          return;
        }
        
        try {
          const center = globalBoundingBox.getCenter(new THREE.Vector3());
          const size = globalBoundingBox.getSize(new THREE.Vector3());
          
          // Вычисляем оптимальное расстояние
          const maxDim = Math.max(size.x, size.y, size.z);
          const distance = Math.max(maxDim * 1.5, 10);
          
          // Устанавливаем камеру
          camera.position.set(
            center.x + distance,
            center.y + distance * 0.5,
            center.z + distance
          );
          
          controls.target.copy(center);
          controls.update();
          
          addDebug(`📷 Камера центрирована на сцене`, 'success');
          
        } catch (e) {
          addDebug(`❌ Ошибка: ${e.message}`, 'error');
        }
      };
      
      // Инициализация Three.js
      function initThree() {
        addDebug('Инициализация Three.js...', 'info');
        
        try {
          const container = document.getElementById('canvas-container');
          if (!container) {
            addDebug('❌ Контейнер не найден', 'error');
            return;
          }
          
          // Очищаем контейнер
          while (container.firstChild) {
            container.removeChild(container.firstChild);
          }
          
          scene = new THREE.Scene();
          scene.background = new THREE.Color(0x1a1a2e);
          
          camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 1000000);
          camera.position.copy(defaultCameraPosition);
          camera.lookAt(defaultCameraTarget);
          
          renderer = new THREE.WebGLRenderer({ 
            antialias: true,
            powerPreference: "high-performance"
          });
          renderer.setSize(window.innerWidth, window.innerHeight);
          renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
          renderer.shadowMap.enabled = false;
          container.appendChild(renderer.domElement);
          
          addDebug('✓ Рендерер создан', 'success');
          
          // Освещение
          const ambientLight = new THREE.AmbientLight(0x808080);
          scene.add(ambientLight);
          
          const dirLight1 = new THREE.DirectionalLight(0xffffff, 1);
          dirLight1.position.set(5, 10, 7);
          scene.add(dirLight1);
          
          const dirLight2 = new THREE.DirectionalLight(0xffaa88, 0.5);
          dirLight2.position.set(-5, 5, -5);
          scene.add(dirLight2);
          
          // Вспомогательные элементы
          const gridHelper = new THREE.GridHelper(1000, 20, 0x88aaff, 0x335588);
          scene.add(gridHelper);
          
          const axesHelper = new THREE.AxesHelper(100);
          scene.add(axesHelper);
          
          addDebug('✓ Освещение и сетка добавлены', 'success');
          
          // Управление
          controls = new THREE.OrbitControls(camera, renderer.domElement);
          controls.enableDamping = true;
          controls.dampingFactor = 0.05;
          controls.screenSpacePanning = true;
          controls.maxDistance = 100000;
          controls.target.copy(defaultCameraTarget);
          controls.update();
          
          addDebug('✓ Управление настроено', 'success');
          addDebug('✅ Сцена готова', 'success');
          
          // Запускаем анимацию
          startAnimation();
          
        } catch (e) {
          addDebug(`❌ Ошибка: ${e.message}`, 'error');
          console.error(e);
        }
      }

      // Запуск анимации
      function startAnimation() {
        if (animationId) {
          cancelAnimationFrame(animationId);
        }
        
        function animate() {
          if (renderer && scene && camera && controls) {
            controls.update();
            renderer.render(scene, camera);
            animationId = requestAnimationFrame(animate);
          }
        }
        
        animate();
      }

      // ШАГ 1: Выбор JSON
      window.step1_SelectManifest = function() {
        const input = document.createElement('input');
        input.type = 'file';
        input.accept = '.json';
        
        input.onchange = function(e) {
          const file = e.target.files[0];
          if (!file) return;
          
          addDebug(`📋 Загрузка манифеста: ${file.name}`, 'info');
          
          const reader = new FileReader();
          
          reader.onload = function(e) {
            try {
              currentManifest = JSON.parse(e.target.result);
              
              if (currentManifest.format === "navis3dexporter-manifest" && currentManifest.parts) {
                addDebug(`✅ Манифест содержит ${currentManifest.parts.length} моделей`, 'success');
                
                document.getElementById('manifest-info').style.display = 'block';
                document.getElementById('manifest-details').innerHTML = `
                  Файлов GLTF: ${currentManifest.parts.length}
                `;
                
                document.getElementById('step2-btn').disabled = false;
                document.getElementById('step2-btn').style.opacity = '1';
                
                addDebug('👉 Теперь выберите ВСЕ файлы модели', 'success');
              } else {
                addDebug('❌ Неверный формат манифеста', 'error');
              }
            } catch (error) {
              addDebug(`❌ Ошибка: ${error.message}`, 'error');
            }
          };
          
          reader.readAsText(file);
        };
        
        input.click();
      };

      // ШАГ 2: Выбор всех файлов
      window.step2_SelectAllFiles = function() {
        if (!currentManifest) {
          addDebug('❌ Сначала загрузите манифест', 'error');
          return;
        }
        
        if (loadingInProgress) {
          addDebug('⏳ Загрузка уже выполняется, подождите...', 'warning');
          return;
        }
        
        const input = document.createElement('input');
        input.type = 'file';
        input.multiple = true;
        input.accept = '.gltf,.bin';
        
        input.onchange = function(e) {
          const files = Array.from(e.target.files);
          addDebug(`📁 Выбрано файлов: ${files.length}`, 'info');
          
          // Сортируем файлы
          fileManager = {
            gltf: new Map(),
            bin: new Map()
          };
          
          files.forEach(file => {
            const ext = file.name.split('.').pop().toLowerCase();
            if (ext === 'gltf') {
              fileManager.gltf.set(file.name, file);
            } else if (ext === 'bin') {
              fileManager.bin.set(file.name, file);
            }
          });
          
          // Показываем списки
          updateFileLists();
          document.getElementById('file-info').style.display = 'block';
          
          addDebug(`📊 GLTF: ${fileManager.gltf.size}, BIN: ${fileManager.bin.size}`, 'info');
          
          // Сбрасываем глобальный bounding box
          globalBoundingBox = new THREE.Box3();
          hasModels = false;
          
          // Загружаем модели
          const parts = currentManifest.parts;
          let loaded = 0;
          let total = parts.length;
          
          loadingInProgress = true;
          
          function loadNextModel(index) {
            if (index >= parts.length) {
              loadingInProgress = false;
              addDebug('✅ Все модели обработаны', 'success');
              document.getElementById('status').innerHTML = '✅ Все модели загружены';
              
              // Центрируем камеру на всех моделях
              setTimeout(() => {
                window.centerScene();
              }, 500);
              
              return;
            }
            
            const part = parts[index];
            const gltfFile = fileManager.gltf.get(part.file);
            
            if (gltfFile) {
              addDebug(`🔄 Загрузка ${index + 1}/${total}: ${part.label || part.file}`, 'info');
              document.getElementById('status').innerHTML = `⏳ Загрузка: ${part.label || part.file}`;
              
              loadModelWithDependencies(gltfFile, part.label || part.file)
                .then((modelInfo) => {
                  loaded++;
                  updateProgress(loaded, total);
                  
                  // Обновляем глобальный bounding box
                  if (modelInfo && modelInfo.box) {
                    if (!hasModels) {
                      globalBoundingBox.copy(modelInfo.box);
                      hasModels = true;
                    } else {
                      globalBoundingBox.union(modelInfo.box);
                    }
                    
                    sceneCenter.copy(globalBoundingBox.getCenter(new THREE.Vector3()));
                    sceneSize.copy(globalBoundingBox.getSize(new THREE.Vector3()));
                    
                    addDebug(`📊 Текущий центр сцены: (${sceneCenter.x.toFixed(2)}, ${sceneCenter.y.toFixed(2)}, ${sceneCenter.z.toFixed(2)})`, 'info');
                  }
                  
                  setTimeout(() => loadNextModel(index + 1), 300);
                })
                .catch((error) => {
                  addDebug(`❌ Ошибка загрузки ${part.file}`, 'error');
                  loaded++;
                  updateProgress(loaded, total);
                  setTimeout(() => loadNextModel(index + 1), 300);
                });
            } else {
              addDebug(`⚠️ GLTF не найден: ${part.file}`, 'warning');
              loaded++;
              updateProgress(loaded, total);
              setTimeout(() => loadNextModel(index + 1), 100);
            }
          }
          
          loadNextModel(0);
        };
        
        input.click();
      };

      // Обновление списков файлов
      function updateFileLists() {
        const gltfList = document.getElementById('gltf-files-list');
        const binList = document.getElementById('bin-files-list');
        
        gltfList.innerHTML = '';
        fileManager.gltf.forEach((file, name) => {
          gltfList.innerHTML += `<div>📄 ${name}</div>`;
        });
        
        binList.innerHTML = '';
        fileManager.bin.forEach((file, name) => {
          binList.innerHTML += `<div>💾 ${name}</div>`;
        });
      }

      // Загрузка модели
      function loadModelWithDependencies(gltfFile, modelName) {
        return new Promise((resolve, reject) => {
          const reader = new FileReader();
          
          reader.onload = function(e) {
            const arrayBuffer = e.target.result;
            const loader = new THREE.GLTFLoader();
            
            // Создаем URL для BIN файлов
            const binUrls = new Map();
            fileManager.bin.forEach((file, name) => {
              binUrls.set(name, URL.createObjectURL(file));
            });
            
            // Перехватываем загрузку ресурсов
            loader.manager.setURLModifier((url) => {
              if (binUrls.has(url)) {
                return binUrls.get(url);
              }
              return url;
            });
            
            loader.parse(
              arrayBuffer,
              '',
              function(gltf) {
                // Очищаем созданные URL
                binUrls.forEach(url => URL.revokeObjectURL(url));
                
                const model = gltf.scene;
                
                // Вычисляем bounding box модели
                const box = new THREE.Box3().setFromObject(model);
                const center = box.getCenter(new THREE.Vector3());
                const size = box.getSize(new THREE.Vector3());
                
                addDebug(`📐 Модель "${modelName}" размер: ${size.x.toFixed(2)} x ${size.y.toFixed(2)} x ${size.z.toFixed(2)}`, 'info');
                addDebug(`📍 Позиция: (${center.x.toFixed(2)}, ${center.y.toFixed(2)}, ${center.z.toFixed(2)})`, 'info');
                
                // Добавляем модель в сцену без изменений
                scene.add(model);
                
                const modelId = 'model_' + Date.now() + '_' + Math.random();
                modelsMap.set(modelId, {
                  mesh: model,
                  name: modelName,
                  visible: true,
                  box: box.clone(),
                  center: center.clone(),
                  size: size.clone()
                });
                
                addDebug(`✅ Загружена: ${modelName}`, 'success');
                
                updateModelsList();
                updateModelStats();
                
                // Возвращаем информацию о модели
                resolve({
                  box: box,
                  center: center,
                  size: size
                });
              },
              undefined,
              function(error) {
                // Очищаем URL в случае ошибки
                binUrls.forEach(url => URL.revokeObjectURL(url));
                addDebug(`❌ Ошибка парсинга: ${error.message}`, 'error');
                reject(error);
              }
            );
          };
          
          reader.onerror = function(error) {
            addDebug(`❌ Ошибка чтения`, 'error');
            reject(error);
          };
          
          reader.readAsArrayBuffer(gltfFile);
        });
      }

      // Обновление прогресса
      function updateProgress(loaded, total) {
        const percent = (loaded / total * 100).toFixed(0);
        document.getElementById('progress-fill').style.width = percent + '%';
        document.getElementById('progress-text').innerHTML = `${loaded}/${total} (${percent}%)`;
      }

      // Обновление списка моделей
      function updateModelsList() {
        const container = document.getElementById('model-list');
        
        if (modelsMap.size === 0) {
          container.innerHTML = 'Нет загруженных моделей';
          return;
        }
        
        let html = '';
        modelsMap.forEach((modelData, id) => {
          const center = modelData.center || { x: 0, y: 0, z: 0 };
          html += `
            <div class="model-item ${modelData.visible ? 'active' : ''}" onclick="window.toggleModelVisibility('${id}')">
              <div class="model-name">${modelData.name}</div>
              <div class="model-position">
                📍 X:${center.x.toFixed(1)} Y:${center.y.toFixed(1)} Z:${center.z.toFixed(1)}
              </div>
              <div>${modelData.visible ? '👁️ Видима' : '👁️ Скрыта'}</div>
            </div>
          `;
        });
        
        container.innerHTML = html;
      }

      window.toggleModelVisibility = function(modelId) {
        const modelData = modelsMap.get(modelId);
        if (modelData) {
          modelData.visible = !modelData.visible;
          modelData.mesh.visible = modelData.visible;
          
          // Пересчитываем глобальный bounding box
          recalculateGlobalBoundingBox();
          
          updateModelsList();
          window.centerScene();
        }
      };

      function recalculateGlobalBoundingBox() {
        globalBoundingBox = new THREE.Box3();
        hasModels = false;
        
        modelsMap.forEach(modelData => {
          if (modelData.visible) {
            if (!hasModels) {
              globalBoundingBox.copy(modelData.box);
              hasModels = true;
            } else {
              globalBoundingBox.union(modelData.box);
            }
          }
        });
        
        if (hasModels) {
          sceneCenter.copy(globalBoundingBox.getCenter(new THREE.Vector3()));
          sceneSize.copy(globalBoundingBox.getSize(new THREE.Vector3()));
        }
      }

      window.clearAllModels = function() {
        modelsMap.forEach(modelData => {
          if (modelData.mesh) scene.remove(modelData.mesh);
        });
        modelsMap.clear();
        hasModels = false;
        globalBoundingBox = new THREE.Box3();
        sceneCenter.set(0, 0, 0);
        sceneSize.set(0, 0, 0);
        
        updateModelsList();
        updateModelStats();
        document.getElementById('file-info').style.display = 'none';
        document.getElementById('manifest-info').style.display = 'none';
        document.getElementById('step2-btn').disabled = true;
        document.getElementById('step2-btn').style.opacity = '0.5';
        currentManifest = null;
        loadingInProgress = false;
        document.getElementById('status').innerHTML = '⚪ Сцена очищена';
        addDebug('🗑️ Все модели удалены', 'info');
        
        // Возвращаем камеру
        resetCamera();
      };

      function updateModelStats() {
        let meshes = 0, vertices = 0;
        
        modelsMap.forEach(modelData => {
          if (modelData.mesh) {
            modelData.mesh.traverse(node => {
              if (node.isMesh) {
                meshes++;
                if (node.geometry?.attributes.position) {
                  vertices += node.geometry.attributes.position.count;
                }
              }
            });
          }
        });
        
        document.getElementById('model-stats').innerHTML = `
          Моделей: ${modelsMap.size}<br>
          Мешей: ${meshes}<br>
          Вершин: ${vertices.toLocaleString()}<br>
          Центр: X:${sceneCenter.x.toFixed(1)} Y:${sceneCenter.y.toFixed(1)} Z:${sceneCenter.z.toFixed(1)}
        `;
      }

      // Тестовая модель
      window.loadTestModel = function() {
        clearAllModels();
        
        // Создаем несколько объектов на разных позициях
        const positions = [
          { x: -5, y: 1, z: -5, color: 0xff4444 },
          { x: 5, y: 1, z: 5, color: 0x44aaff },
          { x: -5, y: 1, z: 5, color: 0x88ff88 },
          { x: 5, y: 1, z: -5, color: 0xffaa44 }
        ];
        
        positions.forEach((pos, i) => {
          const geometry = new THREE.BoxGeometry(2, 2, 2);
          const material = new THREE.MeshStandardMaterial({ color: pos.color });
          const cube = new THREE.Mesh(geometry, material);
          cube.position.set(pos.x, pos.y, pos.z);
          scene.add(cube);
          
          const box = new THREE.Box3().setFromObject(cube);
          
          const modelId = 'test_' + Date.now() + '_' + i;
          modelsMap.set(modelId, {
            mesh: cube,
            name: `Тест ${i + 1}`,
            visible: true,
            box: box.clone(),
            center: box.getCenter(new THREE.Vector3()),
            size: box.getSize(new THREE.Vector3())
          });
          
          if (i === 0) {
            globalBoundingBox.copy(box);
          } else {
            globalBoundingBox.union(box);
          }
        });
        
        hasModels = true;
        sceneCenter.copy(globalBoundingBox.getCenter(new THREE.Vector3()));
        sceneSize.copy(globalBoundingBox.getSize(new THREE.Vector3()));
        
        updateModelsList();
        updateModelStats();
        
        setTimeout(() => {
          window.centerScene();
        }, 100);
        
        addDebug('✅ Тестовые модели загружены', 'success');
      };

      // Обработка изменения размера окна
      window.addEventListener('resize', () => {
        if (camera) {
          camera.aspect = window.innerWidth / window.innerHeight;
          camera.updateProjectionMatrix();
        }
        if (renderer) {
          renderer.setSize(window.innerWidth, window.innerHeight);
        }
      });
      
      // Запуск
      window.addEventListener('load', () => {
        initThree();
        addDebug('✅ Система готова', 'success');
      });
    </script>
  </body>
</html>
